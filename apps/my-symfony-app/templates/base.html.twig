<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Speed Transport{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>

{% block body %}{% endblock %}

{% block javascripts %}
    {% if app.request.pathInfo starts with '/admin' %}
    <script src="{{ asset('js/bootstrap.bundle.min.js') }}"></script>
    <script>
    window.editServiceKine = function(btn) {
        const id = btn.getAttribute('data-id');
        fetch('/admin/service/' + id, { method: 'GET' })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('serviceModalLabel').textContent = 'Modifier un service';
                    document.getElementById('serviceId').value = id;
                    document.getElementById('serviceName').value = data.service.name;
                    document.getElementById('serviceCategory').value = data.service.categorie.id;
                    document.getElementById('servicePrice').value = data.service.price;
                    const modal = new bootstrap.Modal(document.getElementById('serviceModal'));
                    modal.show();
                } else {
                    alert('Service non trouvé');
                }
            });
    }
    window.deleteServiceKine = function(btn) {
        if (!confirm('Voulez-vous vraiment supprimer ce service ?')) return;
        const id = btn.getAttribute('data-id');
        fetch('/admin/service/delete/' + id, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) { btn.closest('tr').remove(); }
                else { alert(data.message || 'Erreur lors de la suppression'); }
            });
    }
    window.editCentreKine = function(btn) {
        const id = btn.getAttribute('data-id');
        fetch('/admin/centre/' + id, { method: 'GET' })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('centreModalLabel').textContent = 'Modifier un centre';
                    document.getElementById('centreId').value = id;
                    document.getElementById('centreNom').value = data.centre.nom;
                    document.getElementById('centreAdresse').value = data.centre.adresse || '';
                    document.getElementById('centreMapX').value = data.centre.map_x || '';
                    document.getElementById('centreMapY').value = data.centre.map_y || '';
                    const modal = new bootstrap.Modal(document.getElementById('centreModal'));
                    modal.show();
                } else { alert('Centre non trouvé'); }
            });
    }
    window.deleteCentreKine = function(btn) {
        if (!confirm('Voulez-vous vraiment supprimer ce centre ?')) return;
        const id = btn.getAttribute('data-id');
        fetch('/admin/centre/delete/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(json => { if (json.success) { btn.closest('tr').remove(); } else { alert(json.message || 'Erreur lors de la suppression'); } });
    }
    </script>
    {% endif %}
{% endblock %}

</body>
</html>
