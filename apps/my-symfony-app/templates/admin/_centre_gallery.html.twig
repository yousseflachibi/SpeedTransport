{# Partial: gallery for a centre #}
<div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
  <div class="dashboard-title mb-0">Galerie - Centre {{ centre ? centre.nom : 'Inconnu' }}</div>
  <button class="btn btn-secondary" onclick="if(window.loadPartial) window.loadPartial('/admin/partial/centres-kine')">Retour</button>
</div>

{% if not centre %}
  <div class="alert alert-danger">Centre introuvable.</div>
{% else %}
  <div id="gallery-root" class="dashboard-card" data-centre-id="{{ centre.id }}">
    <div class="mb-3 d-flex align-items-end gap-2">
      <div class="flex-grow-1">
        <label for="newImageFile" class="form-label">Ajouter une image (fichier)</label>
        <input type="file" class="form-control" id="newImageFile" accept="image/*">
      </div>
      <button id="uploadImageBtn" class="btn btn-primary">Ajouter</button>
    </div>
    <div id="galleryError" class="alert alert-danger" style="display:none"></div>
    <div class="row g-3">
      {% for img in images %}
        <div class="col-6 col-md-3">
          <div class="card h-100">
            <img src="{{ img.url }}" class="card-img-top" alt="image">
            <div class="card-body d-flex justify-content-between align-items-center">
              <small class="text-muted">{{ img.createdAt|date('Y-m-d H:i') }}</small>
              <button class="btn btn-sm btn-outline-danger gallery-delete-btn" data-id="{{ img.id }}">Supprimer</button>
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-12"><div class="text-muted">Aucune image pour ce centre.</div></div>
      {% endfor %}
    </div>
  </div>
  <script>
    (function(){
      const uploadBtn = document.getElementById('uploadImageBtn');
      const fileEl = document.getElementById('newImageFile');
      const errEl = document.getElementById('galleryError');
      if(uploadBtn && fileEl){
        uploadBtn.onclick = function(){
          const file = fileEl.files && fileEl.files[0];
          if(!file){ errEl.textContent = 'Fichier requis'; errEl.style.display='block'; return; }
          errEl.style.display='none';
          const fd = new FormData();
          fd.append('image', file);
          fetch('/admin/centre/{{ centre.id }}/image/upload', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(json => {
              if(json.success){ if(window.loadPartial) window.loadPartial('/admin/partial/centre/{{ centre.id }}/gallery'); }
              else { errEl.textContent = json.message || 'Erreur'; errEl.style.display='block'; }
            })
            .catch(() => { errEl.textContent = 'Erreur réseau'; errEl.style.display='block'; });
        };
      }
      document.querySelectorAll('.gallery-delete-btn').forEach(btn => {
        btn.onclick = function(){
          const id = btn.getAttribute('data-id');
          fetch('/admin/centre/image/delete/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(json => { if(json.success){ if(window.loadPartial) window.loadPartial('/admin/partial/centre/{{ centre.id }}/gallery'); } else { alert(json.message || 'Erreur'); } })
            .catch(()=>{ alert('Erreur réseau'); });
        };
      });
    })();
  </script>
{% endif %}
