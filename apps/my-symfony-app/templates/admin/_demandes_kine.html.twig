{# Partial: liste des demandes kine #}
<div id="demandes-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Demandes Kiné</div>
        <div class="d-flex align-items-center gap-3">
            {% if is_admin or is_user %}
            <div class="form-check form-switch me-3">
                <input class="form-check-input" type="checkbox" id="filterSuiviToday" {{ suiviToday ? 'checked' : '' }}>
                <label class="form-check-label" for="filterSuiviToday">Suivi aujourd'hui</label>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="filterNoSuivi" {{ noSuivi ? 'checked' : '' }}>
                <label class="form-check-label" for="filterNoSuivi">Sans date de suivi</label>
            </div>
            <div>
                <label class="form-label mb-0 me-2" for="filterStatus">Statut</label>
                <select id="filterStatus" class="form-select form-select-sm d-inline-block" style="width:auto;">
                    <option value="">Tous</option>
                    <option value="0" {{ statusFilter is not null and statusFilter == 0 ? 'selected' : '' }}>En attente</option>
                    <option value="1" {{ statusFilter is not null and statusFilter == 1 ? 'selected' : '' }}>Acceptée</option>
                    <option value="2" {{ statusFilter is not null and statusFilter == 2 ? 'selected' : '' }}>Rejetée</option>
                    <option value="3" {{ statusFilter is not null and statusFilter == 3 ? 'selected' : '' }}>En cours</option>
                </select>
            </div>
            {% endif %}
            <button class="btn btn-primary" id="addDemandeBtn">Ajouter</button>
        </div>
    </div>
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>CIN</th>
                    <th>Ville</th>
                    <th>Date de demande</th>
                    <th>Date de suivi</th>
                    <th>Statut</th>
                    <th>Zone Kiné</th>
                    <th>Services</th>
                    {% if not is_agent or is_admin or is_user %}
                        <th>Actions</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for demande in demandes %}
                <tr data-id="{{ demande.id }}" class="demande-row" style="cursor: pointer;">
                    <td>{{ loop.index }}</td>
                    <td>{{ demande.cin ?? '-' }}</td>
                    <td>{{ villesMap[demande.idVille] ?? '-' }}</td>
                    <td>{{ demande.dateDemande ? demande.dateDemande|date('Y-m-d H:i') : '-' }}</td>
                    <td>{{ demande.dateSuivi ? demande.dateSuivi|date('Y-m-d H:i') : '-' }}</td>
                    <td>
                        {% if demande.status == 1 %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #28a745;"></span>
                            <span style="margin-left: 5px;">Acceptée</span>
                        {% elseif demande.status == 2 %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #dc3545;"></span>
                            <span style="margin-left: 5px;">Rejetée</span>
                        {% elseif demande.status == 3 %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #007bff;"></span>
                            <span style="margin-left: 5px;">En cours</span>
                        {% else %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #fd7e14;"></span>
                            <span style="margin-left: 5px;">En attente</span>
                        {% endif %}
                    </td>
                    <td>{{ zonesMap[demande.idZone] ?? '-' }}</td>
                    <td>
                        {% if demande.services is defined and demande.services|length > 0 %}
                            {% for s in demande.services %}
                                <span class="badge bg-light text-dark">{{ s.name }}</span>
                            {% endfor %}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    {% if not is_agent or is_admin or is_user %}
                        <td onclick="event.stopPropagation();">
                            <button class="btn btn-sm btn-info demande-detail-btn" data-id="{{ demande.id }}">Détails</button>
                        </td>
                    {% endif %}
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center">Aucune demande</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        {# Pagination #}
        {% if totalPages > 1 %}
        <div class="d-flex justify-content-between align-items-center mt-3 px-3 pb-3">
            <div class="text-muted">
                Page {{ currentPage }} sur {{ totalPages }} ({{ totalCount }} demande{{ totalCount > 1 ? 's' : '' }})
            </div>
            <nav aria-label="Pagination demandes">
                <ul class="pagination mb-0">
                    <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                        <a class="page-link demandes-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a>
                    </li>
                    
                    {% for page in 1..totalPages %}
                        {% if page == 1 or page == totalPages or (page >= currentPage - 2 and page <= currentPage + 2) %}
                            <li class="page-item {{ page == currentPage ? 'active' : '' }}">
                                <a class="page-link demandes-page-link" href="#" data-page="{{ page }}">{{ page }}</a>
                            </li>
                        {% elseif page == currentPage - 3 or page == currentPage + 3 %}
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        {% endif %}
                    {% endfor %}
                    
                    <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                        <a class="page-link demandes-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a>
                    </li>
                </ul>
            </nav>
        </div>
        {% endif %}
    </div>
</div>

<!-- Modal Demande Kiné -->
<div class="modal fade" id="demandeModal" tabindex="-1" aria-labelledby="demandeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="demandeModalLabel">Ajouter une demande</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="demandeForm">
                    <input type="hidden" id="demandeId" value="">
                    <div id="demandeFormError" style="display:none;" class="alert alert-danger"></div>
                    
                    <h6 class="mb-3 text-primary">Informations personnelles</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeNomPrenom" class="form-label">Nom & Prénom *</label>
                            <input type="text" class="form-control" id="demandeNomPrenom" name="nom_prenom" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeCin" class="form-label">CIN *</label>
                            <input type="text" class="form-control" id="demandeCin" name="cin" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nom Agent</label>
                            <div class="form-control" style="background:#f8f9fa;" readonly>
                                {{ app.user and app.user.fullName ? app.user.fullName : (app.user ? app.user.email : '-') }}
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="demandeEmail" name="email">
                        </div>
                    </div>

                    <h6 class="mb-3 text-primary">Contact</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeNumeroTele" class="form-label">Numéro de téléphone *</label>
                            <input type="text" class="form-control" id="demandeNumeroTele" name="numero_tele" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeNumeroTeleWtp" class="form-label">Numéro WhatsApp</label>
                            <input type="text" class="form-control" id="demandeNumeroTeleWtp" name="numero_tele_wtp">
                        </div>
                    </div>

                    <h6 class="mb-3 text-primary">Détails de la demande</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeVille" class="form-label">Ville</label>
                            <select class="form-control" id="demandeVille" name="id_ville">
                                <option value="">Sélectionner une ville</option>
                                {% if villes is defined %}
                                    {% for v in villes %}
                                        <option value="{{ v.id }}">{{ v.nom }}</option>
                                    {% endfor %}
                                {% endif %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeZone" class="form-label">Zone Kiné</label>
                            <select class="form-control" id="demandeZone" name="id_zone">
                                <option value="">Sélectionner une zone</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeNombreSeance" class="form-label">Nombre de séances *</label>
                            <input type="number" class="form-control" id="demandeNombreSeance" name="nombre_seance" required value="1">
                        </div>
                        <div class="col-12 mb-3">
                            <label for="demandeMotif" class="form-label">Motif</label>
                            <textarea class="form-control" id="demandeMotif" name="motif_kine" rows="3"></textarea>
                        </div>
                        <div class="col-12 mb-3">
                            <label for="demandeServices" class="form-label">Services demandés</label>
                            <select id="demandeServices" name="services[]" class="form-select" multiple size="6">
                                {% for s in services %}
                                    <option value="{{ s.id }}" data-categorie="{{ s.categorie ? s.categorie.nom : 'Sans catégorie' }}">{{ s.name }}</option>
                                {% endfor %}
                            </select>
                            <div class="d-flex align-items-center mt-2 gap-2">
                                <small class="text-muted" id="demandeServicesCount">0 sélectionné</small>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="demandeServicesClearBtn">Effacer la sélection</button>
                            </div>
                            <small class="text-muted">Maintenir Ctrl/Cmd pour sélection multiple.</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="saveDemandeBtn">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterSuiviToday = document.getElementById('filterSuiviToday');
    const filterNoSuivi = document.getElementById('filterNoSuivi');
    const villeSelect = document.getElementById('demandeVille');
    const zoneSelect = document.getElementById('demandeZone');

    function loadZonesForVille(ville) {
        if (!zoneSelect) return;
        zoneSelect.innerHTML = '<option value="">Chargement…</option>';
        if (!ville) {
            zoneSelect.innerHTML = '<option value="">Sélectionner une zone</option>';
            return;
        }
        fetch('{{ path('admin_zones_by_ville') }}?ville=' + encodeURIComponent(ville))
            .then(r => r.json())
            .then(data => {
                zoneSelect.innerHTML = '';
                const def = document.createElement('option');
                def.value = '';
                def.textContent = 'Sélectionner une zone';
                zoneSelect.appendChild(def);
                if (data.success && Array.isArray(data.zones)) {
                    data.zones.forEach(z => {
                        const opt = document.createElement('option');
                        opt.value = z.id;
                        opt.textContent = z.nom;
                        zoneSelect.appendChild(opt);
                    });
                }
            })
            .catch(() => {
                zoneSelect.innerHTML = '<option value="">Erreur de chargement</option>';
            });
    }

    if (villeSelect) {
        villeSelect.addEventListener('change', function() {
            loadZonesForVille(this.value);
        });

        // Charger zones si une ville est déjà sélectionnée (cas d'édition)
        if (villeSelect.value) {
            loadZonesForVille(villeSelect.value);
        }
    }

    // Filtre suivi aujourd'hui
    if (filterSuiviToday && !filterSuiviToday.__bound) {
        filterSuiviToday.addEventListener('change', function() {
            const params = new URLSearchParams();
            if (this.checked) params.append('suivi_today', '1');
            // si on active "suivi aujourd'hui", désactiver "sans suivi"
            if (this.checked && filterNoSuivi) filterNoSuivi.checked = false;
            const url = '{{ path('admin_partial_demandes_kine') }}' + (params.toString() ? ('?' + params.toString()) : '');
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.text())
                .then(html => {
                    document.getElementById('main-content').innerHTML = html;
                    if (window.attachDemandesKineHandlers) window.attachDemandesKineHandlers();
                })
                .catch(err => console.error('Erreur lors du filtrage des demandes:', err));
        });
        filterSuiviToday.__bound = true;
    }

    // Filtre sans date de suivi
    if (filterNoSuivi && !filterNoSuivi.__bound) {
        filterNoSuivi.addEventListener('change', function() {
            const params = new URLSearchParams();
            if (this.checked) params.append('no_suivi', '1');
            // si on active "sans suivi", désactiver "suivi aujourd'hui"
            if (this.checked && filterSuiviToday) filterSuiviToday.checked = false;
            const url = '{{ path('admin_partial_demandes_kine') }}' + (params.toString() ? ('?' + params.toString()) : '');
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.text())
                .then(html => {
                    document.getElementById('main-content').innerHTML = html;
                    if (window.attachDemandesKineHandlers) window.attachDemandesKineHandlers();
                })
                .catch(err => console.error('Erreur lors du filtrage sans suivi:', err));
        });
        filterNoSuivi.__bound = true;
    }

    // Quand le modal s'affiche, recharger selon ville sélectionnée
    const modalEl = document.getElementById('demandeModal');
    if (modalEl && villeSelect) {
        modalEl.addEventListener('shown.bs.modal', function() {
            if (villeSelect.value) {
                loadZonesForVille(villeSelect.value);
            } else {
                zoneSelect.innerHTML = '<option value="">Sélectionner une zone</option>';
            }
        });
    }

    // Initialisation de Choices.js pour le multi-select des services
    const servicesSel = document.getElementById('demandeServices');
