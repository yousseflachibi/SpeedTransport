{# Partial: liste des demandes kine #}
<div id="demandes-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Demandes Kiné</div>
        <button class="btn btn-primary" id="addDemandeBtn">Ajouter</button>
    </div>
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>CIN</th>
                    <th>Date de demande</th>
                    <th>Statut</th>
                    <th>Zone Kiné</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for demande in demandes %}
                <tr data-id="{{ demande.id }}" class="demande-row" style="cursor: pointer;">
                    <td>{{ loop.index }}</td>
                    <td>{{ demande.cin ?? '-' }}</td>
                    <td>{{ demande.dateDemande ? demande.dateDemande|date('Y-m-d H:i') : '-' }}</td>
                    <td>
                        {% if demande.status == 1 %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #28a745;"></span>
                            <span style="margin-left: 5px;">Acceptée</span>
                        {% elseif demande.status == 2 %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #dc3545;"></span>
                            <span style="margin-left: 5px;">Rejetée</span>
                        {% else %}
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #fd7e14;"></span>
                            <span style="margin-left: 5px;">En attente</span>
                        {% endif %}
                    </td>
                    <td>{{ zonesMap[demande.idZone] ?? '-' }}</td>
                    <td onclick="event.stopPropagation();">
                        <button class="btn btn-sm btn-info demande-detail-btn" data-id="{{ demande.id }}">Détails</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">Aucune demande</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Demande Kiné -->
<div class="modal fade" id="demandeModal" tabindex="-1" aria-labelledby="demandeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="demandeModalLabel">Ajouter une demande</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="demandeForm">
                    <input type="hidden" id="demandeId" value="">
                    <div id="demandeFormError" style="display:none;" class="alert alert-danger"></div>
                    
                    <h6 class="mb-3 text-primary">Informations personnelles</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeNomPrenom" class="form-label">Nom & Prénom *</label>
                            <input type="text" class="form-control" id="demandeNomPrenom" name="nom_prenom" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeCin" class="form-label">CIN *</label>
                            <input type="text" class="form-control" id="demandeCin" name="cin" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeFonction" class="form-label">Fonction</label>
                            <input type="text" class="form-control" id="demandeFonction" name="fonction">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="demandeEmail" name="email">
                        </div>
                    </div>

                    <h6 class="mb-3 text-primary">Contact</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeNumeroTele" class="form-label">Numéro de téléphone *</label>
                            <input type="text" class="form-control" id="demandeNumeroTele" name="numero_tele" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeNumeroTeleWtp" class="form-label">Numéro WhatsApp</label>
                            <input type="text" class="form-control" id="demandeNumeroTeleWtp" name="numero_tele_wtp">
                        </div>
                    </div>

                    <h6 class="mb-3 text-primary">Détails de la demande</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="demandeZone" class="form-label">Zone Kiné</label>
                            <select class="form-control" id="demandeZone" name="id_zone">
                                <option value="">Sélectionner une zone</option>
                                {% for zoneId, zoneNom in zonesMap %}
                                    <option value="{{ zoneId }}">{{ zoneNom }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="demandeNombreSeance" class="form-label">Nombre de séances *</label>
                            <input type="number" class="form-control" id="demandeNombreSeance" name="nombre_seance" required value="1">
                        </div>
                        <div class="col-12 mb-3">
                            <label for="demandeMotif" class="form-label">Motif</label>
                            <textarea class="form-control" id="demandeMotif" name="motif_kine" rows="3"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="saveDemandeBtn">Enregistrer</button>
            </div>
        </div>
    </div>
</div>
