{# Partial: Détail d'une demande kiné #}
<style>
    .demande-detail-container {
        max-width: 100%;
        padding: 20px;
    }
    .detail-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 30px;
    }
    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f0f0;
    }
    .detail-title {
        font-size: 24px;
        font-weight: 600;
        color: #333;
    }
    .form-section {
        margin-bottom: 25px;
    }
    .form-section h5 {
        color: #2563eb;
        margin-bottom: 15px;
        font-weight: 600;
    }
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    .info-item {
        padding: 12px;
        background: #f8f9fa;
        border-radius: 6px;
    }
    .info-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 5px;
    }
    .info-value {
        font-size: 16px;
        color: #333;
        font-weight: 500;
    }
    @media (max-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="demande-detail-container">
    <div class="detail-card">
        <div class="detail-header">
            <h2 class="detail-title">Détail de la demande #{{ demande.id }}</h2>
            <button type="button" class="btn btn-secondary" id="backToListBtn">
                <i class="lni lni-arrow-left"></i> Retour
            </button>
        </div>

        <form id="demandeForm" method="POST" action="{{ path('admin_demande_update', {'id': demande.id}) }}">
            <div class="form-section">
                <h5>Informations personnelles</h5>
                <div class="info-grid">
                    <div class="mb-3">
                        <label for="nom_prenom" class="form-label">Nom & Prénom</label>
                        <input type="text" class="form-control" id="nom_prenom" name="nom_prenom" value="{{ demande.nomPrenom }}">
                    </div>
                    <div class="mb-3">
                        <label for="cin" class="form-label">CIN</label>
                        <input type="text" class="form-control" id="cin" name="cin" value="{{ demande.cin }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nom Agent</label>
                        <div class="form-control" style="background:#f8f9fa;" readonly>
                            {{ demande.nomAgent ?: (app.user and app.user.fullName ? app.user.fullName : (app.user ? app.user.email : '-')) }}
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" value="{{ demande.email }}">
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5>Contact</h5>
                <div class="info-grid">
                    <div class="mb-3">
                        <label for="numero_tele" class="form-label">Numéro de téléphone</label>
                        <input type="text" class="form-control" id="numero_tele" name="numero_tele" value="{{ demande.numeroTele }}">
                    </div>
                    <div class="mb-3">
                        <label for="numero_tele_wtp" class="form-label">Numéro WhatsApp</label>
                        <input type="text" class="form-control" id="numero_tele_wtp" name="numero_tele_wtp" value="{{ demande.numeroTeleWtp }}">
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5>Détails de la demande</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="info-label">Date de demande</label>
                        <div class="info-value">{{ demande.dateDemande ? demande.dateDemande|date('Y-m-d H:i') : '-' }}</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ville</label>
                        <input type="text" class="form-control" value="{{ ville ? ville.nom : '-' }}" disabled style="background-color: #e9ecef;">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="id_zone" class="form-label">Zone Kiné</label>
                        <select class="form-control" id="id_zone" name="id_zone">
                            <option value="">Sélectionner une zone</option>
                            {% if zone %}
                                <option value="{{ zone.id }}" selected>{{ zone.nom }}</option>
                            {% endif %}
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="status" class="form-label">Statut</label>
                        <select class="form-control" id="status" name="status">
                            <option value="0" {{ demande.status == 0 ? 'selected' : '' }}>En attente</option>
                            <option value="1" {{ demande.status == 1 ? 'selected' : '' }}>Acceptée</option>
                            <option value="2" {{ demande.status == 2 ? 'selected' : '' }}>Rejetée</option>
                            <option value="3" {{ demande.status == 3 ? 'selected' : '' }}>En cours</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="nombre_seance" class="form-label">Nombre de séances</label>
                        <input type="number" class="form-control" id="nombre_seance" name="nombre_seance" value="{{ demande.nombreSeance }}">
                    </div>
                    <div class="col-12 mb-3">
                        <label for="demandeDetailServices" class="form-label">Services demandés</label>
                        <select id="demandeDetailServices" name="services[]" class="form-select" multiple size="6">
                            {% for s in services %}
                                <option value="{{ s.id }}" 
                                    {% if demande.services is defined %}
                                        {% for ds in demande.services %}
                                            {% if ds.id == s.id %}selected{% endif %}
                                        {% endfor %}
                                    {% endif %}
                                    data-categorie="{{ s.categorie ? s.categorie.nom : 'Sans catégorie' }}">{{ s.name }}</option>
                            {% endfor %}
                        </select>
                        <div class="d-flex align-items-center mt-2 gap-2">
                            <small class="text-muted" id="demandeDetailServicesCount">0 sélectionné</small>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="demandeDetailServicesClearBtn">Effacer la sélection</button>
                        </div>
                        <small class="text-muted">Maintenir Ctrl/Cmd pour sélection multiple.</small>
                    </div>

                    {# Section Recommandation Centre Kiné #}
                    <div class="col-12 mb-4">
                        <div class="card" style="border: 1px solid #dee2e6;">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="lni lni-hospital"></i> Recommandation de Centre Kiné</h6>
                            </div>
                            <div class="card-body">
                                {% if centresRecommandes is not empty %}
                                    <div class="alert alert-info mb-3">
                                        <i class="lni lni-information"></i> 
                                        {{ centresRecommandes|length }} centre(s) recommandé(s) dans <strong>{{ ville.nom }}</strong> 
                                        proposant au moins un des services demandés
                                    </div>
                                    
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle" id="centresRecommandationTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 60px; text-align: center;">
                                                        <div class="form-check d-flex justify-content-center mb-0">
                                                            <input type="checkbox" class="form-check-input" id="selectAllCentres" style="width: 20px; height: 20px; cursor: pointer;">
                                                        </div>
                                                    </th>
                                                    <th>Nom</th>
                                                    <th>Zone</th>
                                                    <th>Adresse</th>
                                                    <th style="text-align: center;">Services</th>
                                                    <th>Services proposés</th>
                                                </tr>
                                            </thead>
                                            <tbody id="centresRecommandationBody">
                                                {% for item in centresRecommandes %}
                                                    <tr data-centre-id="{{ item.centre.id }}" class="centre-row" style="cursor: pointer;">
                                                        <td style="text-align: center;">
                                                            <div class="form-check d-flex justify-content-center mb-0">
                                                                <input type="checkbox" class="form-check-input centre-checkbox" value="{{ item.centre.id }}" style="width: 20px; height: 20px; cursor: pointer;">
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <strong>{{ item.centre.nom }}</strong>
                                                            {% if item.memeZone %}
                                                                <span class="badge bg-success ms-1" title="Même zone que le patient">
                                                                    <i class="lni lni-checkmark"></i> Même zone
                                                                </span>
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if item.centre.zone %}
                                                                <span class="badge bg-info">{{ item.centre.zone.nom }}</span>
                                                            {% else %}
                                                                <span class="text-muted">-</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>{{ item.centre.adresse|default('-') }}</td>
                                                        <td style="text-align: center;">
                                                            <span class="badge bg-primary">
                                                                {{ item.nombreServicesCommuns }}/{{ item.totalServicesDemandes }}
                                                            </span>
                                                        </td>
                                                        <td>
                                                            {% for service in item.servicesCommuns %}
                                                                <span class="badge bg-secondary me-1 mb-1">
                                                                    {{ service.nom }}
                                                                    {% if service.prix %}
                                                                        - {{ service.prix }} DH
                                                                    {% endif %}
                                                                </span>
                                                            {% endfor %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                    
                                    <!-- Pagination -->
                                    {% if centresRecommandes|length > 10 %}
                                        <nav aria-label="Pagination recommandations">
                                            <ul class="pagination justify-content-center mb-0" id="centresRecommandationPagination">
                                                <!-- Généré par JavaScript -->
                                            </ul>
                                        </nav>
                                    {% endif %}
                                    
                                    <div class="mt-3 d-flex gap-2 align-items-center">
                                        <span id="selectedCentresCount" class="text-muted">0 centre(s) sélectionné(s)</span>
                                        <button type="button" class="btn btn-sm btn-outline-primary" id="assignSelectedCentres">
                                            <i class="lni lni-checkmark-circle"></i> Assigner les centres sélectionnés
                                        </button>
                                    </div>
                                {% else %}
                                    <div class="alert alert-warning">
                                        <i class="lni lni-warning"></i> 
                                        {% if not ville %}
                                            Aucune ville n'est associée à cette demande.
                                        {% elseif demande.services is empty %}
                                            Aucun service n'a été demandé.
                                        {% else %}
                                            Aucun centre kiné trouvé dans <strong>{{ ville.nom }}</strong> proposant les services demandés.
                                        {% endif %}
                                    </div>
                                {% endif %}
                                
                                <hr class="my-4">
                                
                                <h6 class="mb-3">Recherche manuelle</h6>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="zone_recommendation" class="form-label">Zone</label>
                                        <select class="form-select" id="zone_recommendation">
                                            <option value="">-- Chargement des zones --</option>
                                        </select>
                                        <small class="text-muted">
                                            {% if ville %}
                                                Zones disponibles dans {{ ville.nom }}
                                            {% else %}
                                                Aucune ville associée à cette demande
                                            {% endif %}
                                        </small>
                                        <input type="hidden" id="demande_ville_id" value="{{ ville ? ville.id : '' }}">
                                        <input type="hidden" id="demande_id" value="{{ demande.id }}">
                                        <input type="hidden" id="centres_assignes" value="{{ demande.centresAssignes|json_encode }}">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="centre_recommendation" class="form-label">Centre Kiné</label>
                                        <select class="form-select" id="centre_recommendation" disabled>
                                            <option value="">Sélectionner d'abord une zone</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Services proposés</label>
                                        <div id="centre_services_display" class="form-control" style="min-height: 38px; background-color: #f8f9fa; overflow-y: auto; max-height: 100px;">
                                            <small class="text-muted">Sélectionner un centre</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="date_suivi" class="form-label">Date de suivi</label>
                        <input type="datetime-local" class="form-control" id="date_suivi" name="date_suivi" value="{{ demande.dateSuivi ? demande.dateSuivi|date('Y-m-d\\TH:i') : '' }}">
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-primary" id="toggleMapBtn">
                            <i class="lni lni-map"></i> Afficher la carte
                        </button>
                    </div>
                    <div class="col-12 mb-3" id="mapContainer" style="display:none;">
                        <div class="card" style="border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                            <div class="card-body" style="padding:15px;">
                                <div class="row g-2 align-items-center mb-2">
                                    <div class="col-md-8">
                                        <input type="text" class="form-control" id="mapSearchInput" placeholder="Rechercher une adresse, lieu ou ville...">
                                    </div>
                                    <div class="col-md-4 d-flex gap-2">
                                        <button type="button" class="btn btn-primary" id="mapSearchBtn">
                                            <i class="lni lni-search"></i> Rechercher
                                        </button>
                                    </div>
                                </div>
                                <div style="padding:0;">
                                                                        {% set centresJson = [] %}
                                                                        {% for c in centres %}
                                                                            {% if c.mapX and c.mapY %}
                                                                                {% set centresJson = centresJson|merge([{'lat': c.mapX, 'lng': c.mapY, 'name': c.nom, 'adresse': c.adresse|default('')}]) %}
                                                                            {% endif %}
                                                                        {% endfor %}
                                                                        <div id="leafletMap" data-centres='{{ centresJson|json_encode|e('html_attr') }}' style="width:100%; height:380px; border-radius:6px; overflow:hidden;"></div>
                                    <div id="mapNotice" class="text-muted small mt-2" style="display:none;">
                                        Aucun centre géolocalisé pour l’instant.
                                    </div>
                                    <div class="mt-2 d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary" id="mapUseAdresseBtn">
                                            Utiliser l'adresse de la demande
                                        </button>
                                        <button type="button" class="btn btn-outline-primary" id="mapRecenterBtn">
                                            Recentrer sur les centres
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 mb-3">
                        <label for="motif_kine" class="form-label">Motif</label>
                        <textarea class="form-control" id="motif_kine" name="motif_kine" rows="3">{{ demande.motifKine }}</textarea>
                    </div>
                    <div class="col-12 mb-3">
                        <label for="adresse_rejete" class="form-label">Adresse Patient</label>
                        <textarea class="form-control" id="adresse_rejete" name="adresse_rejete" rows="2">{{ demande.adresseRejete }}</textarea>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-secondary" id="cancelBtn">Annuler</button>
                <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
            </div>
        </form>

        <!-- Section Suivi des échanges -->
        <div class="form-section mt-5">
            <h5>Suivi des échanges</h5>
            <div class="timeline-container" style="position: relative; padding-left: 40px; margin-top: 30px;">
                <!-- Timeline verticale -->
                <div style="position: absolute; left: 15px; top: 0; bottom: 0; width: 2px; background-color: #e0e0e0;"></div>
                
                <div id="timelineList">
                    {% for echange in echanges %}
                    <div class="timeline-item">
                        <div class="timeline-dot {{ demande.status == 1 ? 'accepte' : (demande.status == 0 ? 'en-cours' : '') }}"></div>
                        <div class="timeline-card">
                            <div class="timeline-header">
                                <span class="timeline-type">
                                    {% if echange.type == 'whatsapp' %}
                                        📱 Par WhatsApp
                                    {% else %}
                                        📞 Par appel normal
                                    {% endif %}
                                </span>
                                <span class="timeline-date">{{ echange.dateEchange|date('d/m/Y H:i') }}</span>
                            </div>
                            <div class="timeline-content">{{ echange.commentaire }}</div>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <!-- Formulaire d'ajout de commentaire -->
                <div class="add-comment-section mt-4">
                    <div class="d-flex gap-3 align-items-start">
                        <div style="position: relative;">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background-color: #2563eb; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px;">A</div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="mb-3">
                                <label class="form-label">Type de communication</label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="comm_type" id="commWhatsapp" value="whatsapp" checked>
                                        <label class="form-check-label" for="commWhatsapp">
                                            Par WhatsApp
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="comm_type" id="commAppel" value="appel">
                                        <label class="form-check-label" for="commAppel">
                                            Par appel normal
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <textarea class="form-control" id="newComment" rows="3" placeholder="Ajouter un commentaire sur l'échange..."></textarea>
                            <button type="button" class="btn btn-primary mt-2" id="addCommentBtn">Ajouter</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
        padding-left: 25px;
    }
    .timeline-dot {
        position: absolute;
        left: -24px;
        top: 8px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background-color: #333;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px #e0e0e0;
    }
    .timeline-dot.en-cours { background-color: #fd7e14; }
    .timeline-dot.accepte { background-color: #28a745; }
    .timeline-card {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        border-left: 3px solid #2563eb;
    }
    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
    .timeline-type { font-size: 12px; color: #6c757d; font-weight: 600; }
    .timeline-date { font-size: 12px; color: #6c757d; }
    .timeline-content { color: #333; line-height: 1.6; }
    
    /* Styles pour le tableau de recommandation */
    #centresRecommandationTable tbody tr.centre-row:hover {
        background-color: #f8f9fa;
    }
    #centresRecommandationTable tbody tr.centre-row {
        transition: background-color 0.2s ease;
    }
    #centresRecommandationTable .form-check-input:hover {
        transform: scale(1.1);
        transition: transform 0.2s ease;
    }
    #centresRecommandationTable .form-check-input:checked {
        background-color: #2563eb;
        border-color: #2563eb;
    }
</style>

