{# Partial: Détail d'une demande kiné #}
<style>
    .demande-detail-container {
        max-width: 100%;
        padding: 20px;
    }
    .detail-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 30px;
    }
    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f0f0;
    }
    .detail-title {
        font-size: 24px;
        font-weight: 600;
        color: #333;
    }
    .form-section {
        margin-bottom: 25px;
    }
    .form-section h5 {
        color: #2563eb;
        margin-bottom: 15px;
        font-weight: 600;
    }
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    .info-item {
        padding: 12px;
        background: #f8f9fa;
        border-radius: 6px;
    }
    .info-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 5px;
    }
    .info-value {
        font-size: 16px;
        color: #333;
        font-weight: 500;
    }
    @media (max-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="demande-detail-container">
    <div class="detail-card">
        <div class="detail-header">
            <h2 class="detail-title">Détail de la demande #{{ demande.id }}</h2>
            <button type="button" class="btn btn-secondary" id="backToListBtn">
                <i class="lni lni-arrow-left"></i> Retour
            </button>
        </div>

        <form id="demandeForm" method="POST" action="{{ path('admin_demande_update', {'id': demande.id}) }}">
            <div class="form-section">
                <h5>Informations personnelles</h5>
                <div class="info-grid">
                    <div class="mb-3">
                        <label for="nom_prenom" class="form-label">Nom & Prénom</label>
                        <input type="text" class="form-control" id="nom_prenom" name="nom_prenom" value="{{ demande.nomPrenom }}">
                    </div>
                    <div class="mb-3">
                        <label for="cin" class="form-label">CIN</label>
                        <input type="text" class="form-control" id="cin" name="cin" value="{{ demande.cin }}">
                    </div>
                    <div class="mb-3">
                        <label for="fonction" class="form-label">Fonction</label>
                        <input type="text" class="form-control" id="fonction" name="fonction" value="{{ demande.fonction }}">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" value="{{ demande.email }}">
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5>Contact</h5>
                <div class="info-grid">
                    <div class="mb-3">
                        <label for="numero_tele" class="form-label">Numéro de téléphone</label>
                        <input type="text" class="form-control" id="numero_tele" name="numero_tele" value="{{ demande.numeroTele }}">
                    </div>
                    <div class="mb-3">
                        <label for="numero_tele_wtp" class="form-label">Numéro WhatsApp</label>
                        <input type="text" class="form-control" id="numero_tele_wtp" name="numero_tele_wtp" value="{{ demande.numeroTeleWtp }}">
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5>Détails de la demande</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="info-label">Date de demande</label>
                        <div class="info-value">{{ demande.dateDemande ? demande.dateDemande|date('Y-m-d H:i') : '-' }}</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="id_zone" class="form-label">Zone Kiné</label>
                        <select class="form-control" id="id_zone" name="id_zone">
                            <option value="">Sélectionner une zone</option>
                            {% if zone %}
                                <option value="{{ zone.id }}" selected>{{ zone.nom }}</option>
                            {% endif %}
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="status" class="form-label">Statut</label>
                        <select class="form-control" id="status" name="status">
                            <option value="0" {{ demande.status == 0 ? 'selected' : '' }}>En attente</option>
                            <option value="1" {{ demande.status == 1 ? 'selected' : '' }}>Acceptée</option>
                            <option value="2" {{ demande.status == 2 ? 'selected' : '' }}>Rejetée</option>
                            <option value="3" {{ demande.status == 3 ? 'selected' : '' }}>En cours</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="nombre_seance" class="form-label">Nombre de séances</label>
                        <input type="number" class="form-control" id="nombre_seance" name="nombre_seance" value="{{ demande.nombreSeance }}">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="date_suivi" class="form-label">Date de suivi</label>
                        <input type="datetime-local" class="form-control" id="date_suivi" name="date_suivi" value="{{ demande.dateSuivi ? demande.dateSuivi|date('Y-m-d\\TH:i') : '' }}">
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-primary" id="toggleMapBtn">
                            <i class="lni lni-map"></i> Afficher la carte
                        </button>
                    </div>
                    <div class="col-12 mb-3" id="mapContainer" style="display:none;">
                        <div class="card" style="border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                            <div class="card-body" style="padding:15px;">
                                <div class="row g-2 align-items-center mb-2">
                                    <div class="col-md-8">
                                        <input type="text" class="form-control" id="mapSearchInput" placeholder="Rechercher une adresse, lieu ou ville...">
                                    </div>
                                    <div class="col-md-4 d-flex gap-2">
                                        <button type="button" class="btn btn-primary" id="mapSearchBtn">
                                            <i class="lni lni-search"></i> Rechercher
                                        </button>
                                    </div>
                                </div>
                                <div style="padding:0;">
                                                                        {% set centresJson = [] %}
                                                                        {% for c in centres %}
                                                                            {% if c.mapX and c.mapY %}
                                                                                {% set centresJson = centresJson|merge([{'lat': c.mapX, 'lng': c.mapY, 'name': c.nom, 'adresse': c.adresse|default('')}]) %}
                                                                            {% endif %}
                                                                        {% endfor %}
                                                                        <div id="leafletMap" data-centres='{{ centresJson|json_encode|e('html_attr') }}' style="width:100%; height:380px; border-radius:6px; overflow:hidden;"></div>
                                    <div id="mapNotice" class="text-muted small mt-2" style="display:none;">
                                        Aucun centre géolocalisé pour l’instant.
                                    </div>
                                    <div class="mt-2 d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary" id="mapUseAdresseBtn">
                                            Utiliser l'adresse de la demande
                                        </button>
                                        <button type="button" class="btn btn-outline-primary" id="mapRecenterBtn">
                                            Recentrer sur les centres
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 mb-3">
                        <label for="motif_kine" class="form-label">Motif</label>
                        <textarea class="form-control" id="motif_kine" name="motif_kine" rows="3">{{ demande.motifKine }}</textarea>
                    </div>
                    <div class="col-12 mb-3">
                        <label for="adresse_rejete" class="form-label">Adresse (si rejeté)</label>
                        <textarea class="form-control" id="adresse_rejete" name="adresse_rejete" rows="2">{{ demande.adresseRejete }}</textarea>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="traite_par_notre_cote" class="form-label">Traité par notre côté</label>
                        <select class="form-control" id="traite_par_notre_cote" name="traite_par_notre_cote">
                            <option value="0" {{ demande.traiteParNotreCote == 0 ? 'selected' : '' }}>Non</option>
                            <option value="1" {{ demande.traiteParNotreCote == 1 ? 'selected' : '' }}>Oui</option>
                        </select>
                    </div>
                </div>
            </div>


                            if (bounds.length){ map.fitBounds(bounds, { padding: [20,20] }); } else { map.setView([33.5731, -7.5898], 11); }
                            // Fix layout when shown from hidden container
                            setTimeout(function(){ map.invalidateSize(); }, 0);
                        }
                        // If map already exists, ensure proper sizing after reveal
                        if (leafletDiv && leafletDiv._map){ setTimeout(function(){ leafletDiv._map.invalidateSize(); }, 0); }
                    }
                } catch (e) { console.warn('Leaflet init error', e); }
            });
            // Expose a fallback inline handler for debugging
            window.__toggleMap = function(){
                try {
                    console.log('[DemandeDetail] __toggleMap invoked');
                    var btn = document.getElementById('toggleMapBtn');
                    var container = document.getElementById('mapContainer');
                    if (!btn || !container){
                        console.warn('[DemandeDetail] elements missing');
                        return;
                    }
                    var isHidden = (container.style.display === 'none' || container.style.display === '');
                    console.log('[DemandeDetail] (fallback) hidden?', isHidden);
                    container.style.display = isHidden ? 'block' : 'none';
                    btn.textContent = isHidden ? 'Masquer la carte' : 'Afficher la carte';
                } catch (e){
                    console.error('[DemandeDetail] __toggleMap error', e);
                }
            });
        }
        var backBtn = document.getElementById('backToListBtn');
        if (backBtn && !backBtn._bound){
            backBtn._bound = true;
            backBtn.addEventListener('click', function(){
                console.log('[DemandeDetail] backToListBtn clicked');
                window.location.href = '{{ path('admin_index') }}';
            });
        }
        // Map search handlers
        var searchBtn = document.getElementById('mapSearchBtn');
        var searchInput = document.getElementById('mapSearchInput');
        var useAdresseBtn = document.getElementById('mapUseAdresseBtn');
        var leafletDiv = document.getElementById('leafletMap');
        if (searchBtn && searchInput && leafletDiv && !searchBtn._bound){
            searchBtn._bound = true;
            // Initialize Leaflet if not already
            if (!leafletDiv._map){
                var map = L.map('leafletMap');
                leafletDiv._map = map;
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);
                // Plot centres
                var centresData = [
                    {% for c in centres %}
                        {% if c.mapX and c.mapY %}
                        { id: {{ c.id }}, name: {{ c.nom|json_encode|raw }}, lat: {{ c.mapX|json_encode|raw }}, lng: {{ c.mapY|json_encode|raw }}, adresse: {{ c.adresse|default('')|json_encode|raw }} },
                        {% endif %}
                    {% endfor %}
                ];
                var bounds = [];
                centresData.forEach(function(c){
                    var lat = parseFloat(c.lat), lng = parseFloat(c.lng);
                    if (isFinite(lat) && isFinite(lng)){
                        var m = L.marker([lat, lng]).addTo(map);
                        m.bindPopup('<strong>' + c.name + '</strong><br/>' + (c.adresse || ''));
                        bounds.push([lat, lng]);
                    }
                });
                if (bounds.length){ map.fitBounds(bounds, { padding: [20,20] }); } else { map.setView([33.5731, -7.5898], 11); }
            }
            var mapRef = leafletDiv._map;
            var geocodeQuery = function(q){
                // Basic geocoding via Nominatim
                if (!q) return;
                fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(q))
                    .then(function(r){ return r.json(); })
                    .then(function(results){
                        if (results && results.length){
                            var r0 = results[0];
                            var lat = parseFloat(r0.lat), lon = parseFloat(r0.lon);
                            if (isFinite(lat) && isFinite(lon)){
                                mapRef.setView([lat, lon], 13);
                            }
                        }
                    }).catch(function(err){ console.warn('Geocode error', err); });
            };
            searchBtn.addEventListener('click', function(){
                geocodeQuery(searchInput.value.trim());
            });
            if (searchInput){
                searchInput.addEventListener('keydown', function(e){
                    if (e.key === 'Enter') { e.preventDefault(); geocodeQuery(searchInput.value.trim()); }
                });
            }
            if (useAdresseBtn){
                useAdresseBtn.addEventListener('click', function(){
                    var adresse = document.getElementById('adresse_rejete');
                    var zoneSelect = document.getElementById('id_zone');
                    var zoneText = zoneSelect && zoneSelect.options[zoneSelect.selectedIndex] ? zoneSelect.options[zoneSelect.selectedIndex].text : '';
                    var base = (adresse && adresse.value.trim()) ? adresse.value.trim() : (zoneText || document.getElementById('nom_prenom').value);
                    searchInput.value = base;
                    geocodeQuery(base);
                });
            }
        }
    }
    if (document.readyState === 'loading'){
        document.addEventListener('DOMContentLoaded', function(){
            console.log('[DemandeDetail] DOMContentLoaded');
            attachHandlers();
        });
    } else {
        console.log('[DemandeDetail] document readyState:', document.readyState);
        attachHandlers();
    }
})();
</script>
