{# Partial: centres kine list #}
<div id="centres-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Centre Kiné</div>
        <button class="btn btn-primary" id="addCentreBtn">Ajouter</button>
    </div>

    {# Filtres #}
    <div class="dashboard-card mb-3">
        <form id="centresFilterForm" class="row g-3">
            <div class="col-md-4">
                <label for="filterVille" class="form-label">Ville</label>
                <select class="form-select" id="filterVille" name="ville_id">
                    <option value="">Toutes les villes</option>
                    {% for ville in villes %}
                        <option value="{{ ville.id }}" {{ selectedVilleId == ville.id ? 'selected' : '' }}>
                            {{ ville.nom }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label for="filterZone" class="form-label">Zone</label>
                <select class="form-select" id="filterZone" name="zone_id" {{ not selectedVilleId ? 'disabled' : '' }}>
                    {% if selectedVilleId %}
                        <option value="">Toutes les zones</option>
                        {% for zone in zones %}
                            <option value="{{ zone.id }}" {{ selectedZoneId == zone.id ? 'selected' : '' }}>
                                {{ zone.nom }}
                            </option>
                        {% endfor %}
                    {% else %}
                        <option value="">Sélectionner d'abord une ville</option>
                    {% endif %}
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filtrer</button>
                <button type="button" class="btn btn-secondary" id="resetFiltersBtn">Réinitialiser</button>
            </div>
        </form>
    </div>

    <div class="dashboard-card">
        {# Informations de pagination #}
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted">
                Affichage de {{ centres|length }} centre(s) sur {{ total }} au total
            </div>
            <div>
                Page {{ currentPage }} sur {{ totalPages }}
            </div>
        </div>

        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Zone</th>
                    <th>Adresse</th>
                    <th>Image</th>
                    <th>Map (X,Y)</th>
                    <th>Services</th>
                    <th>Date d'inscription</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for c in centres %}
                <tr data-id="{{ c.id }}">
                    <td>{{ (currentPage - 1) * 10 + loop.index }}</td>
                    <td class="centre-nom">{{ c.nom }}</td>
                    <td class="centre-ville">
                        {{ (c.villeKine ? c.villeKine.nom : (c.zone ? c.zone.ville : '-')) }}
                    </td>
                    <td class="centre-zone">
                        {% if c.zone %}
                            <span class="badge bg-info text-dark">{{ c.zone.nom }}</span>
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td class="centre-adresse">{{ c.adresse }}</td>
                    <td class="centre-image">
                        {% if c.imagePrincipale %}
                            <!--img src="{{ asset(c.imagePrincipale) }}" alt="image" style="height:40px"-->
                            <button type="button" class="btn btn-link p-0 centre-image-view-btn" data-src="{{ asset(c.imagePrincipale) }}">Voir</button>
                        {% else %}-{% endif %}
                    </td>
                    <td class="centre-map">{{ c.mapX }}, {{ c.mapY }}</td>
                    <td class="centre-services">
                        {% if c.services is defined %}
                            {% for s in c.services %}
                                <span class="badge bg-light text-dark">{{ s.name }}</span>
                            {% else %}-{% endfor %}
                        {% else %}-{% endif %}
                    </td>
                    <td class="centre-date">{{ c.dateInscription ? c.dateInscription|date('Y-m-d H:i') : '' }}</td>
                    <td>
                        <button class="btn btn-sm btn-warning centre-edit-btn" data-id="{{ c.id }}">Modifier</button>
                        <button class="btn btn-sm btn-danger centre-delete-btn" data-id="{{ c.id }}">Supprimer</button>
                        <button class="btn btn-sm btn-info centre-gallery-btn" data-id="{{ c.id }}">Gallery</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="10" class="text-center">Aucun centre trouvé</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        {% if totalPages > 1 %}
        <nav aria-label="Pagination centres" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                    <a class="page-link centres-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a>
                </li>
                
                {% for p in 1..totalPages %}
                    {% if p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                        <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                            <a class="page-link centres-page-link" href="#" data-page="{{ p }}">{{ p }}</a>
                        </li>
                    {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    {% endif %}
                {% endfor %}
                
                <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                    <a class="page-link centres-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a>
                </li>
            </ul>
        </nav>
        {% endif %}
    </div>
</div>

<!-- Modal Aperçu Image -->
<div class="modal fade" id="centreImageModal" tabindex="-1" aria-labelledby="centreImageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="centreImageModalLabel">Aperçu de l'image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="centreImagePreview" src="" alt="aperçu" style="max-width:100%;height:auto">
            </div>
        </div>
    </div>
</div>

<!-- Modal Centre Kiné -->
<div class="modal fade" id="centreModal" tabindex="-1" aria-labelledby="centreModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="centreModalLabel">Ajouter un centre</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="centreForm" enctype="multipart/form-data">
                    <input type="hidden" id="centreId" value="">
                    <div id="centreFormError" style="display:none;" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label for="centreNom" class="form-label">Nom</label>
                        <input type="text" class="form-control" id="centreNom" name="nom" required>
                    </div>
                    <div class="mb-3">
                        <label for="centreAdresse" class="form-label">Adresse</label>
                        <textarea class="form-control" id="centreAdresse" name="adresse" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="centreVille" class="form-label">Ville</label>
                        <select class="form-select" id="centreVille" name="ville">
                            <option value="">-- Sélectionner une ville --</option>
                            {% if villes is defined %}
                                {% for v in villes %}
                                    <option value="{{ v.nom }}">{{ v.nom }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="centreZone" class="form-label">Zone Kiné</label>
                        <select class="form-select" id="centreZone" name="zone_id">
                            <option value="">-- Sélectionner une zone --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="centreImage" class="form-label">Image principale</label>
                        <input type="file" class="form-control" id="centreImage" name="image_principale" accept="image/*">
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-end gap-2">
                            <div class="flex-grow-1">
                                <label for="centreServices" class="form-label">Services disponibles</label>
                                <select id="centreServices" name="services[]" class="form-select" multiple size="6">
                                    {% for s in services %}
                                        <option value="{{ s.id }}" data-categorie="{{ s.categorie ? s.categorie.nom : 'Sans catégorie' }}">{{ s.name }}</option>
                                    {% endfor %}
                                </select>
                                <div class="mt-2" id="centreServicesSelected">
                                    <!-- badges des services sélectionnés seront injectés ici -->
                                </div>
                                <div class="d-flex align-items-center mt-2 gap-2">
                                    <small class="text-muted" id="centreServicesCount">0 sélectionné</small>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="centreServicesClearBtn">Effacer la sélection</button>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted">Maintenir Ctrl/Cmd pour sélection multiple.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Adresse Map</label>
                        <div class="d-flex gap-2">
                            <input type="text" class="form-control" id="centreMapX" name="map_x" placeholder="X">
                            <input type="text" class="form-control" id="centreMapY" name="map_y" placeholder="Y">
                            <button type="button" class="btn btn-outline-secondary" id="getCoordsBtn">Récupérer coordonnées</button>
                        </div>
                        <small class="text-muted">Bouton placeholder: à brancher avec une API Maps si besoin.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="submit" form="centreForm" class="btn btn-primary">Enregistrer</button>
            </div>
        </div>
    </div>
</div>