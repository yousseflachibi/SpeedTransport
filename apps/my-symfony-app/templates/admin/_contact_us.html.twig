<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Contact Us</h2>
    </div>

    {# Filtre par sujet #}
    <div class="card mb-3">
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-4">
                    <label for="filterSujet" class="form-label">Filtrer par sujet</label>
                    <select id="filterSujet" class="form-select">
                        <option value="">Tous les sujets</option>
                        <option value="Centre Kiné" {{ sujetFilter == 'Centre Kiné' ? 'selected' : '' }}>Centre Kiné</option>
                        <option value="Patient" {{ sujetFilter == 'Patient' ? 'selected' : '' }}>Patient</option>
                        <option value="Kiné à domicile" {{ sujetFilter == 'Kiné à domicile' ? 'selected' : '' }}>Kiné à domicile</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="filterHasDemande" class="form-label">Demande liée</label>
                    <select id="filterHasDemande" class="form-select">
                        <option value="all" {{ hasDemande == 'all' ? 'selected' : '' }}>Toutes</option>
                        <option value="yes" {{ hasDemande == 'yes' ? 'selected' : '' }}>Avec demande</option>
                        <option value="no" {{ hasDemande == 'no' ? 'selected' : '' }}>Sans demande</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button id="resetFilterBtn" class="btn btn-secondary w-100">
                        <i class="bi bi-x-circle"></i> Réinitialiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted">
                    Affichage de {{ contacts|length }} message(s) sur {{ total }} au total
                </div>
                <div>
                    Page {{ currentPage }} sur {{ totalPages }}
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom complet</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Ville</th>
                            <th>Sujet</th>
                            <th>Message</th>
                            <th>Date</th>
                            <th>Demande</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if contacts is empty %}
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                    <p class="mt-2">Aucun message de contact</p>
                                </td>
                            </tr>
                        {% else %}
                            {% for contact in contacts %}
                                {% set isLinked = linkedContactIds is defined and contact.id in linkedContactIds %}
                                <tr data-id="{{ contact.id }}" data-linked="{{ isLinked ? '1' : '0' }}" data-sujet="{{ contact.choiceList }}" class="{{ not contact.isRead ? 'table-success' : '' }}">
                                    <td>{{ contact.id }}</td>
                                    <td>{{ contact.fullName }}</td>
                                    <td><a href="mailto:{{ contact.email }}">{{ contact.email }}</a></td>
                                    <td>{{ contact.phoneNumber }}</td>
                                    <td>{{ contact.city }}</td>
                                    <td>{{ contact.choiceList }}</td>
                                    <td>
                                        <button class="btn btn-link btn-sm text-start p-0 view-message-btn" 
                                                data-id="{{ contact.id }}"
                                                data-is-read="{{ contact.isRead ? '1' : '0' }}"
                                                data-nom="{{ contact.fullName }}"
                                                data-email="{{ contact.email }}"
                                                data-phone="{{ contact.phoneNumber }}"
                                                data-ville="{{ contact.city }}"
                                                data-sujet="{{ contact.choiceList }}"
                                                data-message="{{ contact.description|escape('html_attr') }}"
                                                data-date="{{ contact.dateAction|date('d/m/Y H:i') }}">
                                            <div class="text-truncate" style="max-width: 200px;">
                                                {{ contact.description }}
                                            </div>
                                        </button>
                                    </td>
                                    <td>{{ contact.dateAction|date('d/m/Y H:i') }}</td>
                                    <td>
                                        {% if isLinked %}
                                            {% set demandeId = linkedMap is defined ? (linkedMap[contact.id] ?? null) : null %}
                                            {% if demandeId %}
                                                <a href="#" class="btn btn-sm btn-outline-primary view-demande-link" data-demande-id="{{ demandeId }}">Voir la demande</a>
                                            {% else %}
                                                <span class="badge bg-primary">Demande créée</span>
                                            {% endif %}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
            
            {# Pagination #}
            {% if totalPages > 1 %}
            <div class="card-footer">
                <nav aria-label="Pagination contacts" class="mt-2">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                            <a class="page-link contact-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a>
                        </li>
                        
                        {% for p in 1..totalPages %}
                            {% if p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                                <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                                    <a class="page-link contact-page-link" href="#" data-page="{{ p }}">{{ p }}</a>
                                </li>
                            {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            {% endif %}
                        {% endfor %}
                        
                        <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                            <a class="page-link contact-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a>
                        </li>
                    </ul>
                </nav>
            </div>
            {% endif %}
        </div>
    </div>
</div>

{# Modal pour visualiser le message #}
<div class="modal fade" id="contactMessageModal" tabindex="-1" aria-labelledby="contactMessageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactMessageModalLabel">Détails du message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Nom complet :</strong>
                        <p id="modalNom" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <strong>Email :</strong>
                        <p id="modalEmail" class="mb-0"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Téléphone :</strong>
                        <p id="modalPhone" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <strong>Ville :</strong>
                        <p id="modalVille" class="mb-0"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Sujet :</strong>
                        <p id="modalSujet" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <strong>Date :</strong>
                        <p id="modalDate" class="mb-0"></p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <strong>Message :</strong>
                        <div id="modalMessage" class="p-3 bg-light rounded mt-2" style="white-space: pre-wrap;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button id="createDemandeBtn" type="button" class="btn btn-primary" style="display:none;">
                    <i class="lni lni-plus"></i> Demande
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>
