        function attachMissingServicesHandlers() {
            const villeSelect = document.getElementById('missing-ville-filter');

            if (villeSelect && window.loadPartial) {
                villeSelect.onchange = function () {
                    const ville = villeSelect.value;
                    let url = '{{ path('admin_partial_missing_services') }}';
                    const params = [];
                    if (ville) { params.push('ville=' + encodeURIComponent(ville)); }
                    if (params.length) { url += '?' + params.join('&'); }
                    loadPartial(url);
                };
            }

            document.querySelectorAll('.missing-services-page-link').forEach(link => {
                link.onclick = function (e) {
                    e.preventDefault();
                    const page = this.dataset.page;
                    let url = '{{ path('admin_partial_missing_services') }}?page=' + page;
                    const ville = villeSelect ? villeSelect.value : '';
                    if (ville) { url += '&ville=' + encodeURIComponent(ville); }
                    if (window.loadPartial) { loadPartial(url); }
                };
            });
        }

        function attachKinePatientHandlers() {
            const centreSelect = document.getElementById('kp-centre');
            const monthSelect = document.getElementById('kp-month');
            const seanceAddModalEl = document.getElementById('seanceAddModal');
            const seanceListModalEl = document.getElementById('seanceListModal');
            const seanceDateInput = document.getElementById('seanceDate');
            const seanceCommentInput = document.getElementById('seanceComment');
            const seanceAddForm = document.getElementById('seanceAddForm');
            const seanceAddError = document.getElementById('seanceAddError');
            const seanceAddSubmit = document.getElementById('seanceAddSubmit');
            const seanceDemandeIdInput = document.getElementById('seanceDemandeId');
            const seanceListEmpty = document.getElementById('seanceListEmpty');
            const seanceTimeline = document.getElementById('seanceListTimeline');
            const seanceTimelineItems = document.getElementById('seanceTimelineItems');
            const seanceRatingStars = document.querySelectorAll('#seanceRatingWrapper .seance-rating-star');
            const seanceRatingInput = document.getElementById('seanceRating');
            let currentSeanceRating = 0;

            const seanceUrlTemplate = '{{ path('admin_demande_seances_list', {'id': 0})|replace({'0':'__ID__'}) }}';

            if (!centreSelect) {
                return;
            }

            function reload(page) {
                const centre = centreSelect.value;
                const month = monthSelect ? monthSelect.value : '';
                let url = '{{ path('admin_partial_kine_patient') }}';
                const params = [];
                if (centre) { params.push('centre=' + encodeURIComponent(centre)); }
                if (month) { params.push('month=' + encodeURIComponent(month)); }
                if (page) { params.push('page=' + encodeURIComponent(page)); }
                if (params.length) { url += '?' + params.join('&'); }
                if (window.loadPartial) { loadPartial(url); }
            }

            centreSelect.onchange = function () {
                if (monthSelect) {
                    monthSelect.disabled = !centreSelect.value;
                }
                reload(1);
            };

            if (monthSelect) {
                monthSelect.onchange = function () {
                    reload(1);
                };
            }

            function setDefaultSeanceDate() {
                if (!seanceDateInput) return;
                const now = new Date();
                const pad = (n) => (n < 10 ? '0' + n : n);
                const formatted = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;
                seanceDateInput.value = formatted;
            }

            function setSeanceRatingDisplay(value) {
                currentSeanceRating = value;
                if (seanceRatingInput) {
                    seanceRatingInput.value = value > 0 ? value : '';
                }
                if (seanceRatingStars && seanceRatingStars.length) {
                    seanceRatingStars.forEach((star) => {
                        const v = parseInt(star.dataset.value, 10);
                        star.classList.toggle('active', v <= value);
                    });
                }
            }

            function openAddSeanceModal(demandeId) {
                if (!seanceAddModalEl) return;
                seanceDemandeIdInput.value = demandeId;
                if (seanceCommentInput) seanceCommentInput.value = '';
                if (seanceAddError) { seanceAddError.style.display = 'none'; seanceAddError.textContent = ''; }
                setDefaultSeanceDate();
                setSeanceRatingDisplay(0);
                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    new bootstrap.Modal(seanceAddModalEl).show();
                }
            }

            function renderSeances(seances) {
                if (!seanceTimelineItems || !seanceListEmpty || !seanceTimeline) return;
                seanceTimelineItems.innerHTML = '';
                if (!seances || !seances.length) {
                    seanceListEmpty.style.display = 'block';
                    seanceTimeline.style.display = 'none';
                    return;
                }
                seanceListEmpty.style.display = 'none';
                seanceTimeline.style.display = 'block';

                const renderStars = (val) => {
                    const rating = parseInt(val, 10) || 0;
                    if (!rating) return '';
                    let stars = '';
                    for (let i = 1; i <= 5; i++) {
                        stars += `<span class="seance-star ${i <= rating ? 'filled' : ''}">★</span>`;
                    }
                    return `<div class="seance-star-row">${stars}</div>`;
                };

                seances.forEach((s) => {
                    const item = document.createElement('div');
                    item.className = 'timeline-item';
                    item.innerHTML = `
                        <div class="timeline-dot en-cours"></div>
                        <div class="timeline-card">
                            <div class="timeline-header">
                                <span class="timeline-type">Séance</span>
                                <span class="timeline-date">${s.dateSeance}</span>
                            </div>
                            <div class="timeline-content">${renderStars(s.rating)}${s.commentaire || ''}</div>
                        </div>
                    `;
                    seanceTimelineItems.appendChild(item);
                });
            }

            function viewSeances(demandeId) {
                if (!seanceListModalEl) return;
                const url = seanceUrlTemplate.replace('__ID__', demandeId);
                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then((r) => r.json())
                    .then((data) => {
                        if (data.success) {
                            renderSeances(data.seances || []);
                            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                                new bootstrap.Modal(seanceListModalEl).show();
                            }
                        } else {
                            alert(data.message || 'Impossible de charger les séances');
                        }
                    })
                    .catch(() => alert('Erreur réseau'));
            }

            if (seanceAddSubmit && seanceAddForm) {
                seanceAddSubmit.onclick = function () {
                    const demandeId = seanceDemandeIdInput.value;
                    const url = seanceUrlTemplate.replace('__ID__', demandeId);
                    const formData = new FormData(seanceAddForm);

                    fetch(url, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then((r) => r.json())
                        .then((data) => {
                            if (data.success) {
                                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                                    const modalInstance = bootstrap.Modal.getInstance(seanceAddModalEl) || new bootstrap.Modal(seanceAddModalEl);
                                    modalInstance.hide();
                                }
                                seanceAddForm.reset();
                                setDefaultSeanceDate();
                            } else {
                                if (seanceAddError) {
                                    seanceAddError.textContent = data.message || 'Erreur lors de l\'ajout';
                                    seanceAddError.style.display = 'block';
                                } else {
                                    alert(data.message || 'Erreur lors de l\'ajout');
                                }
                            }
                        })
                        .catch(() => {
                            if (seanceAddError) {
                                seanceAddError.textContent = 'Erreur réseau';
                                seanceAddError.style.display = 'block';
                            } else {
                                alert('Erreur réseau');
                            }
                        });
                };
            }

            if (seanceRatingStars && seanceRatingStars.length) {
                seanceRatingStars.forEach((star) => {
                    star.addEventListener('click', () => {
                        const val = parseInt(star.dataset.value, 10) || 0;
                        setSeanceRatingDisplay(val);
                    });
                });
            }

            document.querySelectorAll('.seance-add-btn').forEach((btn) => {
                btn.onclick = function () {
                    const demandeId = btn.getAttribute('data-demande-id');
                    if (demandeId) {
                        openAddSeanceModal(demandeId);
                    }
                };
            });

            document.querySelectorAll('.seance-view-btn').forEach((btn) => {
                btn.onclick = function () {
                    const demandeId = btn.getAttribute('data-demande-id');
                    if (demandeId) {
                        viewSeances(demandeId);
                    }
                };
            });

            document.querySelectorAll('.kp-page-link').forEach((link) => {
                link.onclick = function (e) {
                    e.preventDefault();
                    const page = this.dataset.page;
                    if (page) {
                        reload(page);
                    }
                };
            });
        }

        function initChartsIfNeeded() {
            // Revenue chart
            const rev = document.getElementById('revenueChart');
            if (rev) {
                new Chart(rev, {
                    type: 'bar',
                    data: {
                        labels: ['01','02','03','04','05','06','07','08','09','10','11','12'],
                        datasets: [{ label: 'Last 6 days', data: [12,19,3,5,2,3,7,8,6,9,10,11], backgroundColor: '#6c63ff' }, { label: 'Last Week', data: [10,15,2,3,1,2,5,6,4,7,8,9], backgroundColor: '#e0e7ff' }]
                    }, options: { responsive: true, plugins: { legend: { display: false } } }
                });
            }
            const orderTime = document.getElementById('orderTimeChart');
            if (orderTime) {
                // Récupérer les données depuis les attributs data du canvas
                const enAttente = parseInt(orderTime.dataset.enAttente || 0);
                const enCours = parseInt(orderTime.dataset.enCours || 0);
                const acceptee = parseInt(orderTime.dataset.acceptee || 0);
                const refusee = parseInt(orderTime.dataset.refusee || 0);
                
                new Chart(orderTime, { 
                    type: 'doughnut', 
                    data: { 
                        labels: ['En attente', 'En cours', 'Acceptée', 'Refusée'], 
                        datasets: [{ 
                            data: [enAttente, enCours, acceptee, refusee], 
                            backgroundColor: ['#fd7e14', '#007bff', '#28a745', '#dc3545'] 
                        }] 
                    }, 
                    options: { 
                        responsive: true, 
                        plugins: { 
                            legend: { 
                                position: 'bottom',
                                display: false
                            } 
                        } 
                    } 
                });
            }
            
            // Chart: Évolution des demandes (Line Chart)
            const evolutionChart = document.getElementById('evolutionChart');
            if (evolutionChart && evolutionChart.dataset.evolution) {
                // Détruire le chart existant s'il existe
                if (window.evolutionChartInstance) {
                    window.evolutionChartInstance.destroy();
                }
                
                const evolutionData = JSON.parse(evolutionChart.dataset.evolution);
                if (evolutionData && evolutionData.length > 0) {
                    const labels = evolutionData.map(item => {
                        const date = new Date(item.date);
                        return date.getDate() + '/' + (date.getMonth() + 1);
                    });
                    const data = evolutionData.map(item => parseInt(item.total));
                    
                    window.evolutionChartInstance = new Chart(evolutionChart, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Demandes',
                                data: data,
                                borderColor: '#6c63ff',
                                backgroundColor: 'rgba(108,99,255,0.1)',
                                fill: true,
                                tension: 0.4,
                                borderWidth: 2,
                                pointRadius: 3,
                                pointHoverRadius: 5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: { precision: 0 }
                                }
                            }
                        }
                    });
                }
            }
            
            // Chart: Top Villes (Horizontal Bar Chart)
            const topVillesChart = document.getElementById('topVillesChart');
            if (topVillesChart && topVillesChart.dataset.villes) {
                // Détruire le chart existant s'il existe
                if (window.topVillesChartInstance) {
                    window.topVillesChartInstance.destroy();
                }
                
                const topVillesData = JSON.parse(topVillesChart.dataset.villes);
                if (topVillesData && topVillesData.length > 0) {
                    const labels = topVillesData.map(item => item.ville);
                    const data = topVillesData.map(item => parseInt(item.total));
                    
                    const colors = [
                        '#6c63ff', '#ffb347', '#4ecb71', '#ff6b6b', '#4dabf7',
                        '#f06595', '#ffd43b', '#51cf66', '#ff8787', '#74c0fc'
                    ];
                    
                    window.topVillesChartInstance = new Chart(topVillesChart, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Demandes',
                                data: data,
                                backgroundColor: colors.slice(0, data.length),
                                borderRadius: 6
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: { precision: 0 }
                                }
                            }
                        }
                    });
                }
            }
            
            const order = document.getElementById('orderChart');
            if (order) {
                new Chart(order, { type: 'line', data: { labels: ['01','02','03','04','05','06'], datasets: [{ label: 'Last 6 days', data: [400,380,420,390,410,430], borderColor: '#6c63ff', backgroundColor: 'rgba(108,99,255,0.1)', fill: true, tension: 0.4 }] }, options: { responsive: true, plugins: { legend: { display: false } } } });
            }
        }
            
        // Gestionnaire pour le sélecteur de mois (EN DEHORS de initChartsIfNeeded)
        const monthSelector = document.getElementById('monthSelector');
        if (monthSelector && !monthSelector.__monthSelectorBound) {
            monthSelector.addEventListener('change', function() {
                const selectedMonth = this.value;
                if (window.loadPartial) {
                    window.loadPartial('{{ path('admin_partial_dashboard') }}?month=' + selectedMonth);
                }
            });
            monthSelector.__monthSelectorBound = true;
        }

        // Handlers for Users partial (filters)
        function attachUsersHandlers(){
            const form = document.getElementById('userFilterForm');
            if (form && !form.__usersFilterBound){
                form.addEventListener('submit', function(e){
                    e.preventDefault();
                    const params = new URLSearchParams(new FormData(form));
                    if(window.loadPartial){
                        window.loadPartial('{{ path('admin_partial_users') }}' + '?' + params.toString());
                    }
                });
                form.__usersFilterBound = true;
            }

            const addBtn = document.getElementById('addUserBtn');
            const modalEl = document.getElementById('userModal');
            const saveBtn = document.getElementById('saveUserBtn');
            const userForm = document.getElementById('userForm');
            const formError = document.getElementById('userFormError');
            if (addBtn && modalEl && userForm && !addBtn.__userCreateBound){
                addBtn.addEventListener('click', function(){
                    if(userForm) userForm.reset();
                    if(formError) formError.style.display = 'none';
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(modalEl).show();
                });
                addBtn.__userCreateBound = true;
            }
            if (saveBtn && userForm && !saveBtn.__userSaveBound){
                saveBtn.addEventListener('click', function(){
                    if (!userForm.checkValidity()) { userForm.reportValidity(); return; }
                    const fd = new FormData(userForm);
                    fetch('/admin/user/create', { method: 'POST', body: fd })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){
                                const modal = bootstrap.Modal.getInstance(modalEl); if(modal) modal.hide();
                                if(window.loadPartial) window.loadPartial('{{ path('admin_partial_users') }}');
                            } else {
                                if(formError){ formError.textContent = json.message || 'Erreur'; formError.style.display = 'block'; }
                            }
                        })
                        .catch(() => { if(formError){ formError.textContent = 'Erreur réseau'; formError.style.display = 'block'; } });
                });
                saveBtn.__userSaveBound = true;
            }
        }

        // Handlers for Centre Gallery (upload/delete)
        function attachCentreGalleryHandlers(){
            const root = document.getElementById('gallery-root');
            if(!root) return; // not on gallery view
            const centreId = root.getAttribute('data-centre-id');
            const uploadBtn = document.getElementById('uploadImageBtn');
            const fileEl = document.getElementById('newImageFile');
            const errEl = document.getElementById('galleryError');
            if(uploadBtn && fileEl && !uploadBtn.__galleryHandlerAttached){
                uploadBtn.addEventListener('click', function(){
                    const file = fileEl.files && fileEl.files[0];
                    if(!file){ if(errEl){ errEl.textContent = 'Fichier requis'; errEl.style.display='block'; } return; }
                    if(errEl){ errEl.style.display='none'; }
                    const fd = new FormData(); fd.append('image', file);
                    fetch('/admin/centre/' + centreId + '/image/upload', { method: 'POST', body: fd })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){ if(window.loadPartial) window.loadPartial('/admin/partial/centre/' + centreId + '/gallery'); }
                            else { if(errEl){ errEl.textContent = json.message || 'Erreur'; errEl.style.display='block'; } }
                        })
                        .catch(()=>{ if(errEl){ errEl.textContent = 'Erreur réseau'; errEl.style.display='block'; } });
                });
                uploadBtn.__galleryHandlerAttached = true;
            }

            document.querySelectorAll('.gallery-delete-btn').forEach(btn => {
                if(btn.__galleryDeleteAttached) return;
                btn.addEventListener('click', function(){
                    const id = btn.getAttribute('data-id');
                    fetch('/admin/centre/image/delete/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){ if(window.loadPartial) window.loadPartial('/admin/partial/centre/' + centreId + '/gallery'); }
                            else { alert(json.message || 'Erreur'); }
                        })
                        .catch(()=>{ alert('Erreur réseau'); });
                });
                btn.__galleryDeleteAttached = true;
            });
        }
    </script>
{% endblock %}
