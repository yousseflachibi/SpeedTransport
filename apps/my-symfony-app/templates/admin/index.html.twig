            document.querySelectorAll('.centre-gallery-btn').forEach(btn => {
                btn.onclick = function(){
                    const id = btn.getAttribute('data-id');
                    if(window.loadPartial){
                        window.loadPartial('/admin/partial/centre/' + id + '/gallery');
                    }
                };
            });

            // Gestion des filtres et pagination
            const filterForm = document.getElementById('centresFilterForm');
            const resetFiltersBtn = document.getElementById('resetFiltersBtn');
            const filterVilleSelect = document.getElementById('filterVille');
            const filterZoneSelect = document.getElementById('filterZone');
            
            // Charger les zones quand on change la ville dans le filtre
            if (filterVilleSelect && filterZoneSelect) {
                filterVilleSelect.addEventListener('change', function() {
                    const villeId = this.value;
                    
                    if (!villeId) {
                        // Aucune ville sélectionnée : désactiver et vider le select des zones
                        filterZoneSelect.disabled = true;
                        filterZoneSelect.innerHTML = '<option value="">Sélectionner d\'abord une ville</option>';
                    } else {
                        // Charger les zones pour cette ville
                        filterZoneSelect.disabled = true;
                        filterZoneSelect.innerHTML = '<option value="">Chargement...</option>';
                        
                        fetch('{{ path('admin_zones_by_ville') }}?ville=' + villeId)
