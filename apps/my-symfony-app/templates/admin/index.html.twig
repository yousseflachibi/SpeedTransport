{% extends 'base.html.twig' %}

{% block title %}Admin - Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <style>
        .dashboard-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px #0001; padding: 2rem; margin-bottom: 2rem; }
        .dashboard-title { font-size: 1.3rem; font-weight: 600; margin-bottom: 1rem; }
        .dashboard-metric { font-size: 2rem; font-weight: 700; }
        .dashboard-badge { font-size: 0.9rem; border-radius: 1rem; padding: 0.2rem 0.8rem; }
        .dashboard-circle { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 600; color: #fff; margin: 0 auto 0.5rem; }
        .dashboard-circle.hygiene { background: #6c63ff; }
        .dashboard-circle.taste { background: #ffb347; }
        .dashboard-circle.packaging { background: #4ecb71; }
        .admin-logo { background: linear-gradient(135deg, #0d6efd, #4c8dff); border-radius: 12px; padding: 10px 12px; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15); }
        .admin-logo img { height: 34px; width: auto; filter: drop-shadow(0 0 2px rgba(0, 0, 0, 0.15)); }
    </style>
{% endblock %}


{% block body %}
<div class="admin-dashboard d-flex" style="min-height: 100vh; background: #f7f8fa; margin-top: 0;">
    <!-- Sidebar -->
    <nav class="admin-sidebar d-flex flex-column flex-shrink-0 p-3 bg-white border-end" style="width: 240px; min-height: 100vh;">
        <div class="d-flex align-items-center justify-content-center mb-4" style="width: 100%;">
            <div class="admin-logo">
                <img src="{{ asset('images/logo-no-background.png') }}" alt="Allo Kiné" />
            </div>
        </div>
        <ul class="nav nav-pills flex-column mb-auto" id="adminMenu">
            <li class="nav-item"><a href="#" class="nav-link active" data-section="dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
            
            {% if is_admin %}
                <li><a href="#" class="nav-link text-dark" data-section="services-kine"><i class="bi bi-bag-check me-2"></i>Services Kiné</a></li>
                <li><a href="#" class="nav-link text-dark" data-section="zone-kine"><i class="bi bi-list-ul me-2"></i>Zone Kiné</a></li>
                <li><a href="#" class="nav-link text-dark" data-section="centres-kine"><i class="bi bi-hospital me-2"></i>Centre Kiné</a></li>
                <li><a href="#" class="nav-link text-dark" data-section="kine-patient"><i class="bi bi-people me-2"></i>Kiné & Patient</a></li>
            {% endif %}
            
            <li><a href="#" class="nav-link text-dark" data-section="demandes-kine"><i class="bi bi-file-earmark-text me-2"></i>Demande Kiné</a></li>
            
            {% if is_admin %}
                <li><a href="#" class="nav-link text-dark" data-section="users"><i class="bi bi-people me-2"></i>Utilisateurs</a></li>
                <li>
                    <a href="#" class="nav-link text-dark d-flex justify-content-between align-items-center" data-section="contact-us">
                        <span><i class="bi bi-chat-left-text me-2"></i>Contact Us</span>
                        {% if unreadContactCount > 0 %}
                            <span class="badge bg-success rounded-pill" id="unreadContactBadge">{{ unreadContactCount }}</span>
                        {% endif %}
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link text-dark d-flex justify-content-between align-items-center" data-section="missing-services">
                        <span><i class="bi bi-exclamation-octagon me-2"></i>Services manquants</span>
                        {% if missingServicesCount is defined and missingServicesCount > 0 %}
                            <span class="badge bg-primary rounded-pill" id="missingServicesBadge">{{ missingServicesCount }}</span>
                        {% endif %}
                    </a>
                </li>
            {% endif %}
        </ul>
        <div class="mt-auto">
            <hr>
            <ul class="nav nav-pills flex-column mb-2">
                <li><a href="#" class="nav-link text-dark"><i class="bi bi-gear me-2"></i>Settings</a></li>
                <li><a href="#" class="nav-link text-dark"><i class="bi bi-credit-card me-2"></i>Payment</a></li>
                <li><a href="#" class="nav-link text-dark"><i class="bi bi-person me-2"></i>Accounts</a></li>
                    <li><a href="{{ path('logout') }}" class="nav-link text-dark"><i class="bi bi-box-arrow-right me-2"></i>Se déconnecter</a></li>
                    <li><a href="#" class="nav-link text-dark"><i class="bi bi-question-circle me-2"></i>Help</a></li>
            </ul>
        </div>
    </nav>
    <!-- Main dashboard content: zone d'injection des partials -->
    <div class="flex-grow-1 p-4">
        <div id="main-content">
            <!-- les partials (dashboard, services, zone) seront chargés ici via AJAX -->
            <div class="text-center text-muted" style="margin-top:40px">Chargement...</div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script>
        // Menu statique: Centre Kiné est désormais dans le HTML
        // Handler global pour zone kiné
        function attachZoneKineHandlers() {
            const addBtn = document.getElementById('zone-kine-add-btn');
            if (addBtn) {
                addBtn.onclick = function() {
                    document.getElementById('zoneKineModalLabel').textContent = 'Ajouter une zone kiné';
                    document.getElementById('zoneKineForm').reset();
                    document.getElementById('zoneKineId').value = '';
                    document.getElementById('zoneKineFormError').style.display = 'none';
                    var modal = new bootstrap.Modal(document.getElementById('zoneKineModal'));
                    modal.show();
                };
            }
            const form = document.getElementById('zoneKineForm');
            if (form) {
                form.onsubmit = function(e) {
                    e.preventDefault();
                    const idEl = document.getElementById('zoneKineId');
                    const id = idEl ? idEl.value : '';
                    const payload = new FormData(form);
                    const url = id ? ('/admin/zone-kine/update/' + id) : '/admin/zone-kine/create';
                    fetch(url, { method: 'POST', body: payload })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){
                                const modalEl = document.getElementById('zoneKineModal');
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                if(modal) modal.hide();
                                if(window.loadPartial) window.loadPartial('{{ path('admin_partial_zone_kine') }}');
                            } else {
                                document.getElementById('zoneKineFormError').textContent = json.message || 'Erreur';
                                document.getElementById('zoneKineFormError').style.display = 'block';
                            }
                        })
                        .catch(() => {
                            document.getElementById('zoneKineFormError').textContent = 'Erreur réseau';
                            document.getElementById('zoneKineFormError').style.display = 'block';
                        });
                };
            }
            document.querySelectorAll('.zone-kine-edit-btn').forEach(btn => {
                btn.onclick = function() {
                    var tr = btn.closest('tr');
                    document.getElementById('zoneKineId').value = btn.dataset.id || '';
                    document.getElementById('zoneKineNom').value = tr.cells[0].textContent.trim() || '';
                    document.getElementById('zoneKinePrefecture').value = tr.cells[1].textContent.trim() || '';
                    document.getElementById('zoneKineVille').value = tr.cells[2].textContent.trim() || '';
                    document.getElementById('zoneKineCodePostal').value = tr.cells[3].textContent.trim() || '';
                    document.getElementById('zoneKineModalLabel').textContent = 'Modifier Zone Kiné';
                    var modal = new bootstrap.Modal(document.getElementById('zoneKineModal'));
                    modal.show();
                };
            });
            document.querySelectorAll('.zone-kine-delete-btn').forEach(btn => {
                btn.onclick = function() {
                    if(confirm('Voulez-vous vraiment supprimer cette zone ?')) {
                        fetch("{{ path('admin_zone_kine_delete', {'id': 'ZONE_ID'}) }}".replace('ZONE_ID', btn.dataset.id), {
                            method: 'POST'
                        })
                        .then(resp => resp.json())
                        .then(json => {
                            if(json.success) {
                                if(window.loadPartial) window.loadPartial('{{ path('admin_partial_zone_kine') }}');
                            } else {
                                alert(json.message || 'Erreur lors de la suppression');
                            }
                        })
                        .catch(() => {
                            alert('Erreur réseau');
                        });
                    }
                };
            });
            
            // Gestionnaire de pagination
            document.querySelectorAll('.zone-kine-page-link').forEach(link => {
                link.onclick = function(e) {
                    e.preventDefault();
                    const page = this.dataset.page;
                    const villeFilter = document.getElementById('zoneKineVilleFilter');
                    const ville = villeFilter ? villeFilter.value : '';
                    let url = '{{ path('admin_partial_zone_kine') }}?page=' + page;
                    if (ville) {
                        url += '&ville=' + encodeURIComponent(ville);
                    }
                    if(window.loadPartial) {
                        window.loadPartial(url);
                    }
                };
            });
            
            // Gestionnaire de filtre par ville
            const villeFilter = document.getElementById('zoneKineVilleFilter');
            if (villeFilter) {
                villeFilter.onchange = function() {
                    const ville = this.value;
                    let url = '{{ path('admin_partial_zone_kine') }}';
                    if (ville) {
                        url += '?ville=' + encodeURIComponent(ville);
                    }
                    if(window.loadPartial) {
                        window.loadPartial(url);
                    }
                };
            }
        }

        function attachServicesKineHandlers(){
            const addBtn = document.getElementById('addServiceBtn');
            const modalEl = document.getElementById('serviceModal');
            const modalLabel = document.getElementById('serviceModalLabel');
            const form = document.getElementById('serviceForm');
            const formError = document.getElementById('serviceFormError');
            const notifRoot = document.getElementById('service-notif');

            function showServiceNotif(msg){
                if(!notifRoot) return;
                const el = document.createElement('div');
                el.className = 'alert alert-success';
                el.textContent = msg;
                notifRoot.appendChild(el);
                setTimeout(()=>{ el.remove(); }, 2500);
            }

            if(addBtn && modalEl && form){
                addBtn.addEventListener('click', function(){
                    if(modalLabel) modalLabel.textContent = 'Ajouter un service';
                    form.reset();
                    const idEl = document.getElementById('serviceId'); if(idEl) idEl.value = '';
                    if(formError) formError.style.display = 'none';
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        new bootstrap.Modal(modalEl).show();
                    }
                });
            }

            // submit handler (robuste) pour créer/modifier un service
            if (form) {
                // éviter les doublons: supprimer anciens listeners en recréant le nœud ou en utilisant une marque
                if (!form.__serviceHandlerAttached) {
                    form.addEventListener('submit', function(e){
                        e.preventDefault();
                        const id = document.getElementById('serviceId') ? document.getElementById('serviceId').value : '';
                        const data = new FormData(form);
                        const url = id ? '/admin/service/update/' + id : '/admin/service/create';
                        fetch(url, { method: 'POST', body: data })
                            .then(r => r.json())
                            .then(json => {
                                if(json.success){
                                    const modal = bootstrap.Modal.getInstance(modalEl);
                                    if(modal) modal.hide();
                                    if(window.loadPartial) window.loadPartial('/admin/partial/services-kine');
                                } else {
                                    if(formError){ formError.textContent = json.message || 'Erreur'; formError.style.display = 'block'; }
                                }
                            })
                            .catch(() => {
                                if(formError){ formError.textContent = 'Erreur réseau'; formError.style.display = 'block'; }
                            });
                    });
                    form.__serviceHandlerAttached = true;
                }
            }

            // edit buttons
            document.querySelectorAll('.service-kine-edit-btn').forEach(btn => {
                btn.onclick = function(){
                    const id = btn.getAttribute('data-id');
                    fetch('/admin/service/' + id, { method: 'GET' })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                if(modalLabel) modalLabel.textContent = 'Modifier un service';
                                document.getElementById('serviceId').value = id;
                                document.getElementById('serviceName').value = data.service.name;
                                document.getElementById('serviceCategory').value = data.service.categorie.id;
                                document.getElementById('servicePrice').value = data.service.price;
                                if(formError) formError.style.display = 'none';
                                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                                    new bootstrap.Modal(modalEl).show();
                                }
                            } else {
                                alert('Service non trouvé');
                            }
                        });
                };
            });

            // delete buttons
            document.querySelectorAll('.service-kine-delete-btn').forEach(btn => {
                btn.onclick = function(){
                    if(!btn.dataset || !btn.dataset.id) return;
                    if(!confirm('Voulez-vous vraiment supprimer ce service ?')) return;
                    const id = btn.dataset.id;
                    fetch('/admin/service/delete/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){
                                if(window.loadPartial) window.loadPartial('/admin/partial/services-kine');
                            } else {
                                alert(json.message || 'Erreur lors de la suppression');
                            }
                        })
                        .catch(()=>{ alert('Erreur réseau'); });
                };
            });
            
            // Gestionnaire de pagination
            document.querySelectorAll('.service-page-link').forEach(link => {
                link.onclick = function(e) {
                    e.preventDefault();
                    const page = this.dataset.page;
                    const categorieFilter = document.getElementById('serviceCategorieFilter');
                    const categorie = categorieFilter ? categorieFilter.value : '';
                    let url = '{{ path('admin_partial_services_kine') }}?page=' + page;
                    if (categorie) {
                        url += '&categorie=' + encodeURIComponent(categorie);
                    }
                    if(window.loadPartial) {
                        window.loadPartial(url);
                    }
                };
            });
            
            // Gestionnaire de filtre par catégorie
            const categorieFilter = document.getElementById('serviceCategorieFilter');
            if (categorieFilter) {
                categorieFilter.onchange = function() {
                    const categorie = this.value;
                    let url = '{{ path('admin_partial_services_kine') }}';
                    if (categorie) {
                        url += '?categorie=' + encodeURIComponent(categorie);
                    }
                    if(window.loadPartial) {
                        window.loadPartial(url);
                    }
                };
            }
        }

        // Handlers pour Demandes Kiné
        function attachDemandesKineHandlers(){
            const filterSuiviToday = document.getElementById('filterSuiviToday');
            const filterNoSuivi = document.getElementById('filterNoSuivi');
            const filterStatus = document.getElementById('filterStatus');
            const addBtn = document.getElementById('addDemandeBtn');
            const modalEl = document.getElementById('demandeModal');
            const form = document.getElementById('demandeForm');
            const saveBtn = document.getElementById('saveDemandeBtn');
            const formError = document.getElementById('demandeFormError');
            const villeSelect = document.getElementById('demandeVille');
            const zoneSelect = document.getElementById('demandeZone');

            function loadZonesForVille(ville){
                if (!zoneSelect) return;
                zoneSelect.innerHTML = '<option value="">Chargement…</option>';
                if (!ville) { zoneSelect.innerHTML = '<option value="">Sélectionner une zone</option>'; return; }
                fetch('{{ path('admin_zones_by_ville') }}?ville=' + encodeURIComponent(ville))
                    .then(r => r.json())
                    .then(data => {
                        zoneSelect.innerHTML = '';
                        const def = document.createElement('option');
                        def.value = '';
                        def.textContent = 'Sélectionner une zone';
                        zoneSelect.appendChild(def);
                        if (data.success && Array.isArray(data.zones)) {
                            data.zones.forEach(z => {
                                const opt = document.createElement('option');
                                opt.value = z.id;
                                opt.textContent = z.nom;
                                zoneSelect.appendChild(opt);
                            });
                        }
                    })
                    .catch(() => { zoneSelect.innerHTML = '<option value="">Erreur de chargement</option>'; });
            }

            if (addBtn && modalEl && form) {
                addBtn.addEventListener('click', function() {
                    document.getElementById('demandeModalLabel').textContent = 'Ajouter une demande';
                    form.reset();
                    document.getElementById('demandeId').value = '';
                    if (formError) formError.style.display = 'none';
                    new bootstrap.Modal(modalEl).show();
                    // Reset zones when opening
                    if (zoneSelect) zoneSelect.innerHTML = '<option value="">Sélectionner une zone</option>';
                });
            }

            if (villeSelect) {
                villeSelect.addEventListener('change', function(){ loadZonesForVille(this.value); });
            }

            if (modalEl && villeSelect) {
                modalEl.addEventListener('shown.bs.modal', function(){
                    if (villeSelect.value) loadZonesForVille(villeSelect.value);
                });
            }

            // Initialisation de Choices.js pour le multi-select des services
            const servicesSel = document.getElementById('demandeServices');
            if (servicesSel && !servicesSel.__choicesApplied) {
                try {
                    if (!servicesSel.__allOptions) {
                        servicesSel.__allOptions = [...servicesSel.querySelectorAll('option')];
                    }
                    const choices = new Choices(servicesSel, {
                        removeItemButton: true,
                        searchEnabled: true,
                        searchResultLimit: 10,
                        shouldSort: false
                    });
                    servicesSel.__choicesApplied = true;
                    servicesSel.__choicesInstance = choices;

                    // Mise à jour du compteur de services sélectionnés
                    const countEl = document.getElementById('demandeServicesCount');
                    const updateCount = () => {
                        const val = choices.getValue(true);
                        const n = Array.isArray(val) ? val.length : (val ? 1 : 0);
                        if (countEl) countEl.textContent = n + ' sélectionné' + (n > 1 ? 's' : '');
                    };
                    
                    // Écouter les événements Choices.js pour mettre à jour le compteur
                    servicesSel.addEventListener('addItem', updateCount);
                    servicesSel.addEventListener('removeItem', updateCount);
                    servicesSel.addEventListener('change', updateCount);
                    updateCount();

                    // Bouton pour effacer la sélection
                    const clearBtn = document.getElementById('demandeServicesClearBtn');
                    if (clearBtn && !clearBtn.__bound) {
                        clearBtn.addEventListener('click', function() {
                            const inst = servicesSel.__choicesInstance || choices;
                            const allOptions = servicesSel.__allOptions || [...servicesSel.querySelectorAll('option')];
                            inst.removeActiveItems();
                            [...servicesSel.options].forEach(opt => opt.selected = false);
                            inst.clearChoices();
                            inst.setChoices(allOptions.map(opt => ({ 
                                value: opt.value, 
                                label: opt.textContent, 
                                selected: false 
                            })), 'value', 'label', true);
                            updateCount();
                        });
                        clearBtn.__bound = true;
                    }
                } catch (e) {
                    console.error('Erreur Choices.js demandes:', e);
                }
            }

            if (saveBtn && form && !form.__demandeHandlerAttached) {
                saveBtn.addEventListener('click', function() {
                    if (!form.checkValidity()) {
                        form.reportValidity();
                        return;
                    }

                    const formData = new FormData(form);
                    const url = '/admin/demande/create';

                    fetch(url, {
                        method: 'POST',
                        body: formData
                    })
                    .then(r => r.json())
                    .then(json => {
                        if (json.success) {
                            const modal = bootstrap.Modal.getInstance(modalEl);
                            if (modal) modal.hide();
                            if (window.loadPartial) {
                                window.loadPartial('{{ path('admin_partial_demandes_kine') }}');
                            }
                        } else {
                            if (formError) {
                                formError.textContent = json.message || 'Erreur';
                                formError.style.display = 'block';
                            }
                        }
                    })
                    .catch(() => {
                        if (formError) {
                            formError.textContent = 'Erreur réseau';
                            formError.style.display = 'block';
                        }
                    });
                });
                form.__demandeHandlerAttached = true;
            }
            
            // Gérer les clics sur les lignes et boutons détails
            document.querySelectorAll('.demande-row').forEach(row => {
                row.addEventListener('click', function() {
                    const id = this.dataset.id;
                    if (id && window.loadPartial) {
                        window.loadPartial('/admin/demande/' + id);
                    }
                });
            });
            
            document.querySelectorAll('.demande-detail-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    if (id && window.loadPartial) {
                        window.loadPartial('/admin/demande/' + id);
                    }
                });
            });
            
            // Filtre suivi aujourd'hui
            if (filterSuiviToday && !filterSuiviToday.__bound) {
                filterSuiviToday.addEventListener('change', function() {
                    const params = new URLSearchParams();
                    if (this.checked) params.append('suivi_today', '1');
                    const statusSel = document.getElementById('filterStatus');
                    if (statusSel && statusSel.value !== '') params.append('status', statusSel.value);
                    // si on active "suivi aujourd'hui", désactiver "sans suivi"
                    if (this.checked && filterNoSuivi) filterNoSuivi.checked = false;
                    const url = '{{ path('admin_partial_demandes_kine') }}' + (params.toString() ? ('?' + params.toString()) : '');
                    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.text())
                        .then(html => {
                            document.getElementById('main-content').innerHTML = html;
                            attachDemandesKineHandlers();
                        })
                        .catch(err => console.error('Erreur lors du filtrage des demandes:', err));
                });
                filterSuiviToday.__bound = true;
            }
            // Filtre sans suivi
            if (filterNoSuivi && !filterNoSuivi.__bound) {
                filterNoSuivi.addEventListener('change', function() {
                    const params = new URLSearchParams();
                    if (this.checked) params.append('no_suivi', '1');
                    const statusSel = document.getElementById('filterStatus');
                    if (statusSel && statusSel.value !== '') params.append('status', statusSel.value);
                    // si on active "sans suivi", désactiver "suivi aujourd'hui"
                    if (this.checked && filterSuiviToday) filterSuiviToday.checked = false;
                    const url = '{{ path('admin_partial_demandes_kine') }}' + (params.toString() ? ('?' + params.toString()) : '');
                    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.text())
                        .then(html => {
                            document.getElementById('main-content').innerHTML = html;
                            attachDemandesKineHandlers();
                        })
                        .catch(err => console.error('Erreur lors du filtrage sans suivi:', err));
                });
                filterNoSuivi.__bound = true;
            }

            // Filtre statut
            if (filterStatus && !filterStatus.__bound) {
                filterStatus.addEventListener('change', function() {
                    const params = new URLSearchParams();
                    const suivi = document.getElementById('filterSuiviToday');
                    if (suivi && suivi.checked) params.append('suivi_today', '1');
                    if (this.value !== '') params.append('status', this.value);
                    const url = '{{ path('admin_partial_demandes_kine') }}' + (params.toString() ? ('?' + params.toString()) : '');
                    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.text())
                        .then(html => {
                            document.getElementById('main-content').innerHTML = html;
                            attachDemandesKineHandlers();
                        })
                        .catch(err => console.error('Erreur lors du filtrage par statut:', err));
                });
                filterStatus.__bound = true;
            }
            
            // Gestion de la pagination des demandes
            document.querySelectorAll('.demandes-page-link').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const page = this.getAttribute('data-page');
                    if (page && !this.parentElement.classList.contains('disabled') && !this.parentElement.classList.contains('active')) {
                        loadDemandesPage(page);
                    }
                });
            });
            
            function loadDemandesPage(page) {
                const filterSuiviToday = document.getElementById('filterSuiviToday');
                const filterNoSuivi = document.getElementById('filterNoSuivi');
                const filterStatus = document.getElementById('filterStatus');
                const params = new URLSearchParams();
                params.append('page', page);
                if (filterNoSuivi && filterNoSuivi.checked) {
                    params.append('no_suivi', '1');
                } else if (filterSuiviToday && filterSuiviToday.checked) {
                    params.append('suivi_today', '1');
                }
                if (filterStatus && filterStatus.value !== '') {
                    params.append('status', filterStatus.value);
                }
                const url = '{{ path('admin_partial_demandes_kine') }}?' + params.toString();
                
                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('main-content').innerHTML = html;
                        attachDemandesKineHandlers();
                    })
                    .catch(error => console.error('Erreur lors du chargement des demandes:', error));
            }
            
            // Gérer le formulaire de détail
            const demandeForm = document.getElementById('demandeForm');
            if (demandeForm && !demandeForm.__updateHandlerAttached) {
                demandeForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    const formData = new FormData(demandeForm);
                    const url = demandeForm.action;
                    
                    fetch(url, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('Demande mise à jour avec succès');
                            if (window.loadPartial) {
                                window.loadPartial('{{ path('admin_partial_demandes_kine') }}');
                            }
                        } else {
                            alert('Erreur: ' + (data.message || 'Erreur inconnue'));
                        }
                    })
                    .catch(error => {
                        alert('Erreur réseau');
                        console.error('Error:', error);
                    });
                });
                demandeForm.__updateHandlerAttached = true;
            }
            
            // Initialisation de Choices.js pour les services dans la page de détail
            const servicesDetailSel = document.getElementById('demandeDetailServices');
            if (servicesDetailSel && !servicesDetailSel.__choicesApplied) {
                try {
                    if (!servicesDetailSel.__allOptions) {
                        servicesDetailSel.__allOptions = [...servicesDetailSel.querySelectorAll('option')];
                    }
                    const choicesDetail = new Choices(servicesDetailSel, {
                        removeItemButton: true,
                        searchEnabled: true,
                        searchResultLimit: 10,
                        shouldSort: false
                    });
                    servicesDetailSel.__choicesApplied = true;
                    servicesDetailSel.__choicesInstance = choicesDetail;

                    // Mise à jour du compteur de services sélectionnés
                    const countDetailEl = document.getElementById('demandeDetailServicesCount');
                    const updateDetailCount = () => {
                        const val = choicesDetail.getValue(true);
                        const n = Array.isArray(val) ? val.length : (val ? 1 : 0);
                        if (countDetailEl) countDetailEl.textContent = n + ' sélectionné' + (n > 1 ? 's' : '');
                    };
                    
                    // Écouter les événements Choices.js pour mettre à jour le compteur
                    servicesDetailSel.addEventListener('addItem', updateDetailCount);
                    servicesDetailSel.addEventListener('removeItem', updateDetailCount);
                    servicesDetailSel.addEventListener('change', updateDetailCount);
                    updateDetailCount();

                    // Bouton pour effacer la sélection
                    const clearDetailBtn = document.getElementById('demandeDetailServicesClearBtn');
                    if (clearDetailBtn && !clearDetailBtn.__bound) {
                        clearDetailBtn.addEventListener('click', function() {
                            const inst = servicesDetailSel.__choicesInstance || choicesDetail;
                            const allOptions = servicesDetailSel.__allOptions || [...servicesDetailSel.querySelectorAll('option')];
                            inst.removeActiveItems();
                            [...servicesDetailSel.options].forEach(opt => opt.selected = false);
                            inst.clearChoices();
                            inst.setChoices(allOptions.map(opt => ({ 
                                value: opt.value, 
                                label: opt.textContent, 
                                selected: false 
                            })), 'value', 'label', true);
                            updateDetailCount();
                        });
                        clearDetailBtn.__bound = true;
                    }
                } catch (e) {
                    console.error('Erreur Choices.js detail:', e);
                }
            }
            
            // Gérer les boutons retour et annuler
            const backToListBtn = document.getElementById('backToListBtn');
            const cancelBtn = document.getElementById('cancelBtn');
            
            if (backToListBtn) {
                backToListBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (window.loadPartial) {
                        window.loadPartial('{{ path('admin_partial_demandes_kine') }}');
                    }
                });
            }
            
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (window.loadPartial) {
                        window.loadPartial('{{ path('admin_partial_demandes_kine') }}');
                    }
                });
            }
            
            // Gérer l'ajout d'échanges
            const addCommentBtn = document.getElementById('addCommentBtn');
            const newCommentTextarea = document.getElementById('newComment');
            
            if (addCommentBtn && newCommentTextarea) {
                addCommentBtn.addEventListener('click', function() {
                    const commentaire = newCommentTextarea.value.trim();
                    const type = document.querySelector('input[name="comm_type"]:checked')?.value;
                    const demandeId = document.getElementById('demandeForm')?.action.match(/\/(\d+)$/)?.[1];
                    
                    if (!commentaire) {
                        alert('Veuillez entrer un commentaire');
                        return;
                    }
                    
                    if (!demandeId) {
                        alert('ID de demande introuvable');
                        return;
                    }
                    
                    const formData = new FormData();
                    formData.append('type', type);
                    formData.append('commentaire', commentaire);
                    
                    fetch(`/admin/demande/${demandeId}/echange/add`, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Ajouter l'échange à la timeline
                            const timelineList = document.getElementById('timelineList');
                            const newItem = document.createElement('div');
                            newItem.className = 'timeline-item';
                            
                            const typeLabel = type === 'whatsapp' ? '📱 Par WhatsApp' : '📞 Par appel normal';
                            
                            newItem.innerHTML = `
                                <div class="timeline-dot en-cours"></div>
                                <div class="timeline-card">
                                    <div class="timeline-header">
                                        <span class="timeline-type">${typeLabel}</span>
                                        <span class="timeline-date">${data.echange.dateEchange}</span>
                                    </div>
                                    <div class="timeline-content">${data.echange.commentaire}</div>
                                </div>
                            `;
                            
                            timelineList.appendChild(newItem);
                            newCommentTextarea.value = '';
                            alert('Échange ajouté avec succès');
                        } else {
                            alert('Erreur: ' + (data.message || 'Erreur inconnue'));
                        }
                    })
                    .catch(error => {
                        alert('Erreur réseau');
                        console.error('Error:', error);
                    });
                });
            }
        }

        // Handlers pour la section recommandation de centres dans le détail de demande
        function attachDemandeDetailHandlers(){
            const zoneSelect = document.getElementById('zone_recommendation');
            const centreSelect = document.getElementById('centre_recommendation');
            const servicesDisplay = document.getElementById('centre_services_display');
            const villeIdInput = document.getElementById('demande_ville_id');
            
            console.log('attachDemandeDetailHandlers appelé');
            console.log('zoneSelect:', zoneSelect);
            console.log('centreSelect:', centreSelect);
            console.log('servicesDisplay:', servicesDisplay);
            console.log('villeIdInput:', villeIdInput);
            
            // Charger les zones automatiquement si une ville est définie
            if (zoneSelect && villeIdInput && villeIdInput.value) {
                const villeId = villeIdInput.value;
                console.log('Chargement des zones pour la ville ID:', villeId);
                
                fetch('{{ path('admin_zones_by_ville') }}?ville=' + villeId)
                    .then(r => r.json())
                    .then(data => {
                        console.log('Zones reçues:', data);
                        zoneSelect.innerHTML = '<option value="">-- Sélectionner une zone --</option>';
                        
                        if (data.success && Array.isArray(data.zones)) {
                            data.zones.forEach(z => {
                                const opt = document.createElement('option');
                                opt.value = z.id;
                                opt.textContent = z.nom;
                                zoneSelect.appendChild(opt);
                            });
                        }
                    })
                    .catch(err => {
                        console.error('Erreur chargement zones:', err);
                        zoneSelect.innerHTML = '<option value="">Erreur de chargement</option>';
                    });
            } else if (zoneSelect) {
                zoneSelect.innerHTML = '<option value="">Aucune ville associée</option>';
            }
            
            if (zoneSelect && !zoneSelect.__handlerAttached) {
                console.log('Ajout du listener sur zone_recommendation');
                zoneSelect.addEventListener('change', function() {
                    const zoneId = this.value;
                    console.log('Zone sélectionnée:', zoneId);
                    
                    if (!zoneId) {
                        centreSelect.innerHTML = '<option value="">Sélectionner d\'abord une zone</option>';
                        centreSelect.disabled = true;
                        servicesDisplay.innerHTML = '<small class="text-muted">Sélectionner une zone</small>';
                        return;
                    }
                    
                    // Charger les centres de cette zone
                    centreSelect.innerHTML = '<option value="">Chargement...</option>';
                    centreSelect.disabled = true;
                    servicesDisplay.innerHTML = '<small class="text-muted">Sélectionner un centre</small>';
                    
                    const url = '{{ path('admin_centres_by_zone') }}?zone_id=' + zoneId;
                    console.log('Chargement des centres depuis:', url);
                    
                    fetch(url)
                        .then(r => {
                            console.log('Réponse reçue:', r.status);
                            return r.json();
                        })
                        .then(data => {
                            console.log('Données reçues:', data);
                            
                            centreSelect.innerHTML = '<option value="">-- Sélectionner un centre --</option>';
                            
                            if (data.success && Array.isArray(data.centres)) {
                                if (data.centres.length === 0) {
                                    centreSelect.innerHTML = '<option value="">Aucun centre dans cette zone</option>';
                                    console.log('Aucun centre trouvé dans cette zone');
                                } else {
                                    console.log('Centres trouvés:', data.centres.length);
                                    data.centres.forEach(c => {
                                        const opt = document.createElement('option');
                                        opt.value = c.id;
                                        opt.textContent = c.nom + (c.adresse ? ' - ' + c.adresse : '');
                                        centreSelect.appendChild(opt);
                                    });
                                    centreSelect.disabled = false;
                                }
                            } else {
                                console.error('Réponse invalide:', data);
                            }
                        })
                        .catch(err => {
                            console.error('Erreur lors du chargement des centres:', err);
                            centreSelect.innerHTML = '<option value="">Erreur de chargement</option>';
                        });
                });
                zoneSelect.__handlerAttached = true;
            }
            
            if (centreSelect && !centreSelect.__handlerAttached) {
                console.log('Ajout du listener sur centre_recommendation');
                centreSelect.addEventListener('change', function() {
                    const centreId = this.value;
                    console.log('Centre sélectionné:', centreId);
                    
                    if (!centreId) {
                        servicesDisplay.innerHTML = '<small class="text-muted">Sélectionner un centre</small>';
                        return;
                    }
                    
                    // Charger les services de ce centre
                    servicesDisplay.innerHTML = '<small class="text-muted">Chargement...</small>';
                    
                    fetch('{{ path('admin_centre_services', {'id': '__ID__'}) }}'.replace('__ID__', centreId))
                        .then(r => r.json())
                        .then(data => {
                            console.log('Services reçus:', data);
                            if (data.success && Array.isArray(data.services)) {
                                if (data.services.length === 0) {
                                    servicesDisplay.innerHTML = '<small class="text-muted">Aucun service proposé</small>';
                                } else {
                                    servicesDisplay.innerHTML = '';
                                    data.services.forEach(s => {
                                        const badge = document.createElement('span');
                                        badge.className = 'badge bg-primary me-1 mb-1';
                                        badge.textContent = s.name + (s.price ? ' - ' + s.price : '');
                                        servicesDisplay.appendChild(badge);
                                    });
                                }
                            } else {
                                servicesDisplay.innerHTML = '<small class="text-muted">Erreur lors du chargement</small>';
                            }
                        })
                        .catch(() => {
                            servicesDisplay.innerHTML = '<small class="text-muted">Erreur de chargement</small>';
                        });
                });
                centreSelect.__handlerAttached = true;
            }
            
            // Gestion de la pagination du tableau de recommandations
            const table = document.getElementById('centresRecommandationTable');
            const pagination = document.getElementById('centresRecommandationPagination');
            
            if (table) {
                const rowsPerPage = 10;
                const tbody = table.querySelector('tbody');
                const rows = tbody ? Array.from(tbody.querySelectorAll('tr.centre-row')) : [];
                const totalPages = Math.ceil(rows.length / rowsPerPage);
                
                let currentPage = 1;
                
                function showPage(page) {
                    currentPage = page;
                    rows.forEach((row, index) => {
                        const start = (page - 1) * rowsPerPage;
                        const end = start + rowsPerPage;
                        row.style.display = (index >= start && index < end) ? '' : 'none';
                    });
                    
                    if (pagination && totalPages > 1) {
                        renderPagination();
                    }
                }
                
                function renderPagination() {
                    if (!pagination) return;
                    
                    pagination.innerHTML = '';
                    
                    // Bouton Previous
                    const prevLi = document.createElement('li');
                    prevLi.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
                    prevLi.innerHTML = '<a class="page-link" href="#" data-page="prev">Précédent</a>';
                    pagination.appendChild(prevLi);
                    
                    // Numéros de pages
                    for (let i = 1; i <= totalPages; i++) {
                        const li = document.createElement('li');
                        li.className = 'page-item' + (i === currentPage ? ' active' : '');
                        li.innerHTML = `<a class="page-link" href="#" data-page="${i}">${i}</a>`;
                        pagination.appendChild(li);
                    }
                    
                    // Bouton Next
                    const nextLi = document.createElement('li');
                    nextLi.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
                    nextLi.innerHTML = '<a class="page-link" href="#" data-page="next">Suivant</a>';
                    pagination.appendChild(nextLi);
                    
                    // Attacher les événements
                    pagination.querySelectorAll('a.page-link').forEach(link => {
                        link.addEventListener('click', function(e) {
                            e.preventDefault();
                            const page = this.getAttribute('data-page');
                            if (page === 'prev' && currentPage > 1) {
                                showPage(currentPage - 1);
                            } else if (page === 'next' && currentPage < totalPages) {
                                showPage(currentPage + 1);
                            } else if (!isNaN(page)) {
                                showPage(parseInt(page));
                            }
                        });
                    });
                }
                
                // Initialiser la pagination
                if (rows.length > rowsPerPage) {
                    showPage(1);
                }
            }
            
            // Gestion des checkboxes
            const selectAllCheckbox = document.getElementById('selectAllCentres');
            const centreCheckboxes = document.querySelectorAll('.centre-checkbox');
            const selectedCountSpan = document.getElementById('selectedCentresCount');
            const assignBtn = document.getElementById('assignSelectedCentres');
            
            function updateSelectedCount() {
                const checkedCount = document.querySelectorAll('.centre-checkbox:checked').length;
                if (selectedCountSpan) {
                    selectedCountSpan.textContent = checkedCount + ' centre(s) sélectionné(s)';
                }
            }
            
            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    const visibleCheckboxes = Array.from(centreCheckboxes).filter(cb => {
                        const row = cb.closest('tr');
                        return row && row.style.display !== 'none';
                    });
                    
                    visibleCheckboxes.forEach(cb => {
                        cb.checked = this.checked;
                    });
                    updateSelectedCount();
                });
            }
            
            centreCheckboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    updateSelectedCount();
                    
                    // Mettre à jour l'état du "select all"
                    if (selectAllCheckbox) {
                        const visibleCheckboxes = Array.from(centreCheckboxes).filter(cb => {
                            const row = cb.closest('tr');
                            return row && row.style.display !== 'none';
                        });
                        const allChecked = visibleCheckboxes.every(cb => cb.checked);
                        selectAllCheckbox.checked = allChecked && visibleCheckboxes.length > 0;
                    }
                });
            });
            
            if (assignBtn) {
                assignBtn.addEventListener('click', function() {
                    const selectedIds = Array.from(document.querySelectorAll('.centre-checkbox:checked'))
                        .map(cb => parseInt(cb.value));
                    
                    if (selectedIds.length === 0) {
                        alert('Veuillez sélectionner au moins un centre');
                        return;
                    }
                    
                    const demandeId = document.getElementById('demande_id')?.value;
                    if (!demandeId) {
                        alert('ID de demande introuvable');
                        return;
                    }
                    
                    // Désactiver le bouton pendant l'envoi
                    assignBtn.disabled = true;
                    assignBtn.textContent = 'Assignation en cours...';
                    
                    fetch('/admin/demande/' + demandeId + '/assign-centres', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ centreIds: selectedIds })
                    })
                    .then(response => response.json())
                    .then(data => {
                        assignBtn.disabled = false;
                        assignBtn.textContent = 'Assigner les centres sélectionnés';
                        
                        if (data.success) {
                            alert(data.message || 'Centres assignés avec succès');
                            // Mettre à jour le champ caché
                            const centresAssignesInput = document.getElementById('centres_assignes');
                            if (centresAssignesInput) {
                                centresAssignesInput.value = JSON.stringify(selectedIds);
                            }
                        } else {
                            alert('Erreur: ' + (data.message || 'Impossible d\'assigner les centres'));
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        assignBtn.disabled = false;
                        assignBtn.textContent = 'Assigner les centres sélectionnés';
                        alert('Erreur réseau lors de l\'assignation');
                    });
                });
            }
            
            // Pré-cocher les centres déjà assignés
            const centresAssignesInput = document.getElementById('centres_assignes');
            if (centresAssignesInput && centresAssignesInput.value) {
                try {
                    const assignedCentreIds = JSON.parse(centresAssignesInput.value);
                    if (Array.isArray(assignedCentreIds) && assignedCentreIds.length > 0) {
                        assignedCentreIds.forEach(centreId => {
                            const checkbox = document.querySelector('.centre-checkbox[value="' + centreId + '"]');
                            if (checkbox) {
                                checkbox.checked = true;
                            }
                        });
                        updateSelectedCount();
                    }
                } catch(e) {
                    console.error('Erreur parsing centres assignés:', e);
                }
            }
        }

        // Handlers pour Centre Kiné
        function attachCentresKineHandlers(){
            const addBtn = document.getElementById('addCentreBtn');
            const modalEl = document.getElementById('centreModal');
            const modalLabel = document.getElementById('centreModalLabel');
            const form = document.getElementById('centreForm');
            const formError = document.getElementById('centreFormError');
            const villeSelect = document.getElementById('centreVille');
            const zoneSelect = document.getElementById('centreZone');

            function loadCentreZonesForVille(ville){
                if (!zoneSelect) return;
                zoneSelect.innerHTML = '<option value="">Chargement…</option>';
                if (!ville) { zoneSelect.innerHTML = '<option value=\"\">-- Sélectionner une zone --</option>'; return; }
                fetch('{{ path('admin_zones_by_ville') }}?ville=' + encodeURIComponent(ville))
                    .then(r => r.json())
                    .then(data => {
                        zoneSelect.innerHTML = '';
                        const def = document.createElement('option');
                        def.value = '';
                        def.textContent = '-- Sélectionner une zone --';
                        zoneSelect.appendChild(def);
                        if (data.success && Array.isArray(data.zones)) {
                            data.zones.forEach(z => {
                                const opt = document.createElement('option');
                                opt.value = z.id;
                                opt.textContent = z.nom;
                                zoneSelect.appendChild(opt);
                            });
                        }
                    })
                    .catch(() => { zoneSelect.innerHTML = '<option value="">Erreur de chargement</option>'; });
            }
            if(addBtn && modalEl && form){
                addBtn.addEventListener('click', function(){
                    if(modalLabel) modalLabel.textContent = 'Ajouter un centre';
                    form.reset();
                    const idEl = document.getElementById('centreId'); if(idEl) idEl.value = '';
                    if(formError) formError.style.display = 'none';
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        new bootstrap.Modal(modalEl).show();
                    }
                    if (zoneSelect) zoneSelect.innerHTML = '<option value="">-- Sélectionner une zone --</option>';
                });
            }
            if (villeSelect) {
                villeSelect.addEventListener('change', function(){ loadCentreZonesForVille(this.value); });
            }
            if(form && !form.__centreHandlerAttached){
                form.addEventListener('submit', function(e){
                    e.preventDefault();
                    const id = document.getElementById('centreId') ? document.getElementById('centreId').value : '';
                    const data = new FormData(form);
                    const url = id ? '/admin/centre/update/' + id : '/admin/centre/create';
                    fetch(url, { method: 'POST', body: data })
                        .then(r => r.json())
                        .then(json => {
                            if(json.success){
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                if(modal) modal.hide();
                                if(window.loadPartial) window.loadPartial('{{ path('admin_partial_centres_kine') }}');
                            } else {
                                if(formError){ formError.textContent = json.message || 'Erreur'; formError.style.display = 'block'; }
                            }
                        })
                        .catch(() => {
                            if(formError){ formError.textContent = 'Erreur réseau'; formError.style.display = 'block'; }
                        });
                });
                form.__centreHandlerAttached = true;
            }
            // enhance multiselect for services
            const servicesSel = document.getElementById('centreServices');
            const servicesSearch = document.getElementById('centreServicesSearch');
            if(servicesSel && !servicesSel.__choicesApplied){
                try {
                    // Cache original option list before Choices alters the DOM
                    if(!servicesSel.__allOptions){ servicesSel.__allOptions = [...servicesSel.querySelectorAll('option')]; }
                    const choices = new Choices(servicesSel, { removeItemButton: true, searchEnabled: true, searchResultLimit: 10, shouldSort: false });
                    servicesSel.__choicesApplied = true;
                    servicesSel.__choicesInstance = choices;
                    // selection count
                    const countEl = document.getElementById('centreServicesCount');
                    const updateCount = () => {
                        const val = choices.getValue(true);
                        const n = Array.isArray(val) ? val.length : (val ? 1 : 0);
                        if(countEl) countEl.textContent = n + ' sélectionné' + (n>1?'s':'');
                    };
                    choices.passedElement.element.addEventListener('change', updateCount);
                    updateCount();
                    // clear button
                    const clearBtn = document.getElementById('centreServicesClearBtn');
                    if(clearBtn && !clearBtn.__bound){
                        clearBtn.addEventListener('click', function(){
                            const inst = servicesSel.__choicesInstance || choices;
                            const allOptions = servicesSel.__allOptions || [...servicesSel.querySelectorAll('option')];
                            // clear selected tags only
                            inst.removeActiveItems();
                            // clear native selection
                            [...servicesSel.options].forEach(opt => opt.selected = false);
                            // repopulate choices to ensure list stays usable
                            inst.clearChoices();
                            inst.setChoices(allOptions.map(opt => ({ value: opt.value, label: opt.textContent, selected: false })), 'value', 'label', true);
                            // update badges and count
                            const selectedBadgesRoot = document.getElementById('centreServicesSelected');
                            if(selectedBadgesRoot){ selectedBadgesRoot.innerHTML = ''; }
                            updateCount();
                        });
                        clearBtn.__bound = true;
                    }
                    // search box sync: filter choices by text
                    if(servicesSearch && !servicesSearch.__bound){
                        servicesSearch.addEventListener('input', function(){
                            const q = (servicesSearch.value || '').toLowerCase();
                            const allOptions = servicesSel.__allOptions || [...servicesSel.querySelectorAll('option')];
                            const selectedValues = choices.getValue(true);
                            const filtered = allOptions.filter(opt => opt.textContent.toLowerCase().includes(q));
                            choices.clearChoices();
                            choices.setChoices(filtered.map(opt => ({ value: opt.value, label: opt.textContent, selected: selectedValues.includes(opt.value) })), 'value', 'label', true);
                        });
                        servicesSearch.__bound = true;
                    }
                } catch (e) { /* ignore */ }
            }
            const getCoordsBtn = document.getElementById('getCoordsBtn');
            if(getCoordsBtn){
                getCoordsBtn.onclick = function(){
                    // Placeholder: met des valeurs d'exemple
                    const xEl = document.getElementById('centreMapX');
                    const yEl = document.getElementById('centreMapY');
                    if(xEl && yEl){ xEl.value = '33.573110'; yEl.value = '-7.589843'; }
                };
            }
            // bouton Voir pour afficher l'image en grand
            document.querySelectorAll('.centre-image-view-btn').forEach(btn => {
                btn.onclick = function(){
                    const src = btn.getAttribute('data-src');
                    const imgEl = document.getElementById('centreImagePreview');
                    if(imgEl){ imgEl.src = src || ''; }
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        new bootstrap.Modal(document.getElementById('centreImageModal')).show();
                    }
                };
            });
            document.querySelectorAll('.centre-delete-btn').forEach(btn => {
                btn.onclick = function(){
                    if(!btn.dataset || !btn.dataset.id) return;
                    if(!confirm('Voulez-vous vraiment supprimer ce centre ?')) return;
                    const id = btn.dataset.id;
                    fetch('/admin/centre/delete/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(r => r.json())
                        .then(json => { if(json.success){ if(window.loadPartial) window.loadPartial('{{ path('admin_partial_centres_kine') }}'); } else { alert(json.message || 'Erreur lors de la suppression'); } })
                        .catch(()=>{ alert('Erreur réseau'); });
                };
            });

            // edit buttons
            document.querySelectorAll('.centre-edit-btn').forEach(btn => {
                btn.onclick = function(){
                    const id = btn.getAttribute('data-id');
                    fetch('/admin/centre/' + id, { method: 'GET' })
                        .then(r => r.json())
                        .then(data => {
                            if(data.success){
                                const modalEl = document.getElementById('centreModal');
