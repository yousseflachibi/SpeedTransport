                        attachContactUsHandlers();
                    })
                    .catch(error => console.error('Erreur lors du chargement des contacts:', error));
            }

            // Création Demande depuis Contact: binder le bouton du modal
            const demandeBtn = document.getElementById('createDemandeBtn');
            if (demandeBtn && !demandeBtn.__bound) {
                demandeBtn.addEventListener('click', function() {
                    const id = this.dataset.id;
                    if (!id) return;
                    fetch('{{ path('admin_contact_us_create_demande', {id: '__ID__'}) }}'.replace('__ID__', id), {
                        method: 'POST',
                        headers: {'X-Requested-With': 'XMLHttpRequest'}
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            // Recharger la page courante (si connue), sinon page 1
                            const active = document.querySelector('.pagination .page-item.active .page-link');
                            const current = active ? parseInt(active.textContent.trim()) || 1 : 1;
                            loadContactUsWithFilter(current);
                            // Fermer le modal
                            const modalEl = document.getElementById('contactMessageModal');
                            const bsModal = bootstrap.Modal.getInstance(modalEl);
                            if (bsModal) bsModal.hide();
                        } else {
                            alert(data.message || 'Erreur lors de la création de la demande');
                        }
                    })
                    .catch(() => alert('Erreur réseau'));
                });
                demandeBtn.__bound = true;
            }
        }

