{# Partial: catégories de service kiné #}
<div id="categories-kine-root" class="mt-4">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Catégories de Service Kiné</div>
        <button class="btn btn-primary" id="addCategoryBtn">Ajouter</button>
    </div>
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom de la catégorie</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for cat in categories %}
                <tr data-id="{{ cat.id }}">
                    <td class="category-idx">{{ loop.index }}</td>
                    <td class="category-name">{{ cat.nom }}</td>
                    <td>
                        <button class="btn btn-sm btn-warning category-kine-edit-btn" data-id="{{ cat.id }}" onclick="editCategoryKine(this)">Modifier</button>
                        <button class="btn btn-sm btn-danger category-kine-delete-btn" data-id="{{ cat.id }}" onclick="deleteCategoryKine(this)">Supprimer</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="3" class="text-center">Aucune catégorie</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Catégorie Kiné -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="categoryModalLabel">Ajouter une catégorie</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="categoryForm">
                    <input type="hidden" id="categoryId" value="">
                    <div id="categoryFormError" style="display:none;" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label for="categoryName" class="form-label">Nom de la catégorie</label>
                        <input type="text" class="form-control" id="categoryName" name="nom" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="submit" form="categoryForm" class="btn btn-primary">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Notification placeholder for catégories -->
<div id="category-notif" style="position:fixed;top:140px;right:20px;z-index:2000"></div>

<script>
window.editCategoryKine = function(btn) {
    const id = btn.getAttribute('data-id');
    fetch('/admin/category/' + id, { method: 'GET' })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('categoryModalLabel').textContent = 'Modifier une catégorie';
                document.getElementById('categoryId').value = id;
                document.getElementById('categoryName').value = data.category.nom;
                const modal = new bootstrap.Modal(document.getElementById('categoryModal'));
                modal.show();
            } else {
                alert('Catégorie non trouvée');
            }
        });
}

window.deleteCategoryKine = function(btn) {
    if (!confirm('Voulez-vous vraiment supprimer cette catégorie ?')) return;
    const id = btn.getAttribute('data-id');
    const url = '/admin/category/delete/' + id;
    fetch(url, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                btn.closest('tr').remove();
            } else {
                alert(data.message || 'Erreur lors de la suppression');
            }
        });
}
</script>
