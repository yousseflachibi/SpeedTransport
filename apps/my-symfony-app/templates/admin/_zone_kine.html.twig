{# Partial: zone kine list (similar to services) #}
<div id="zone-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Zone Kiné</div>
        <button class="btn btn-primary" id="addZoneKineBtn"><i class="bi bi-plus-circle me-1"></i>Ajouter</button>
    </div>
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Préfecture</th>
                    <th>Ville</th>
                    <th>Code Postal</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if zones is empty %}
                <tr>
                    <td colspan="5" class="text-center text-muted">Aucune zone trouvée</td>
                </tr>
                {% else %}
                    {% for zone in zones %}
                    <tr>
                        <td>{{ zone.nom }}</td>
                        <td>{{ zone.prefecture }}</td>
                        <td>{{ zone.ville }}</td>
                        <td>{{ zone.codePostal }}</td>
                        <td><button class="btn btn-sm btn-outline-secondary">Modifier</button> <button class="btn btn-sm btn-outline-danger">Supprimer</button></td>
                    </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
<script>
    // attach add button handler if loaded directly
    document.addEventListener('DOMContentLoaded', function(){
        const addBtn = document.getElementById('addZoneKineBtn');
        if(addBtn){
            addBtn.addEventListener('click', function(){
                alert('Ouvrir formulaire d\'ajout pour Zone Kiné (à implémenter)');
            });
        }
    });
</script>
