{# Partial: zone kine list (similar to services) #}
<div id="zone-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Zone Kiné</div>
        <button class="btn btn-primary" id="zone-kine-add-btn">Ajouter</button>
    </div>
    
    <div class="dashboard-card mb-3">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label for="zoneKineVilleFilter" class="form-label">Filtrer par ville</label>
                <select class="form-select" id="zoneKineVilleFilter">
                    <option value="">Toutes les villes</option>
                    {% for ville in villesAvecZones %}
                        <option value="{{ ville }}" {% if ville == villeFilter %}selected{% endif %}>{{ ville }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-8 text-end">
                <span class="text-muted">{{ total }} zone(s) trouvée(s)</span>
            </div>
        </div>
    </div>
    
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Préfecture</th>
                    <th>Ville</th>
                    <th>Code Postal</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if zones is empty %}
                <tr>
                    <td colspan="5" class="text-center text-muted">Aucune zone trouvée</td>
                </tr>
                {% else %}
                    {% for zone in zones %}
                    <tr>
                        <td>{{ zone.nom }}</td>
                        <td>{{ zone.prefecture }}</td>
                        <td>{{ zone.ville }}</td>
                        <td>{{ zone.codePostal }}</td>
                        <td>
                            <button class="btn btn-sm btn-warning zone-kine-edit-btn" data-id="{{ zone.id }}">Modifier</button>
                            <button class="btn btn-sm btn-danger zone-kine-delete-btn" data-id="{{ zone.id }}">Supprimer</button>
                        </td>
                    </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
        
        {% if totalPages > 1 %}
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
                Page {{ currentPage }} sur {{ totalPages }} ({{ total }} zone(s) au total)
            </div>
            <nav aria-label="Pagination des zones">
                <ul class="pagination mb-0">
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link zone-kine-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a>
                        </li>
                    {% else %}
                        <li class="page-item disabled">
                            <span class="page-link">Précédent</span>
                        </li>
                    {% endif %}
                    
                    {% for p in 1..totalPages %}
                        {% if p == currentPage %}
                            <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                        {% elseif p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                            <li class="page-item">
                                <a class="page-link zone-kine-page-link" href="#" data-page="{{ p }}">{{ p }}</a>
                            </li>
                        {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                    {% endfor %}
                    
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link zone-kine-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a>
                        </li>
                    {% else %}
                        <li class="page-item disabled">
                            <span class="page-link">Suivant</span>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        </div>
        {% endif %}
    </div>
</div>

<!-- Modal Zone Kiné -->
<div class="modal fade" id="zoneKineModal" tabindex="-1" aria-labelledby="zoneKineModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="zoneKineModalLabel">Ajouter une zone kiné</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="zoneKineForm">
                    <input type="hidden" id="zoneKineId" value="">
                    <div id="zoneKineFormError" style="display:none;" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label for="zoneKineNom" class="form-label">Nom</label>
                        <input type="text" class="form-control" id="zoneKineNom" name="nom" required>
                    </div>
                    <div class="mb-3">
                        <label for="zoneKinePrefecture" class="form-label">Préfecture</label>
                        <input type="text" class="form-control" id="zoneKinePrefecture" name="prefecture" required>
                    </div>
                    <div class="mb-3">
                        <label for="zoneKineVille" class="form-label">Ville</label>
                        <select class="form-select" id="zoneKineVille" name="ville" required>
                            <option value="">Sélectionner une ville</option>
                            {% for ville in villes %}
                                <option value="{{ ville.nom }}">{{ ville.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="zoneKineCodePostal" class="form-label">Code Postal</label>
                        <input type="text" class="form-control" id="zoneKineCodePostal" name="code_postal" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="document.getElementById('zoneKineForm').dispatchEvent(new Event('submit'))">Enregistrer</button>
            </div>
        </div>
    </div>
</div>
