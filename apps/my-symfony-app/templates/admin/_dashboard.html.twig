{# Partial: admin dashboard content #}
<div id="dashboard-root">
    <div class="container-fluid">
        {% if is_admin %}
            {# Vue complète pour les admins #}
            {# Ligne 1: Revenue accepté + Revenue en cours + Demandes par mois #}
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="dashboard-card">
                        <div class="dashboard-title">Revenue Estimé</div>
                        <div class="dashboard-metric">
                            {{ (revenueTotal)|number_format(0, ',', ' ') }} MAD
                            {% if revenueVariation >= 0 %}
                                <span class="dashboard-badge bg-success">+{{ revenueVariation|number_format(1) }}%</span>
                            {% else %}
                                <span class="dashboard-badge bg-danger">{{ revenueVariation|number_format(1) }}%</span>
                            {% endif %}
                        </div>
                        <div class="text-muted mb-2">Demandes acceptées - 90 derniers jours</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="dashboard-card">
                        <div class="dashboard-title">Revenue Potentiel</div>
                        <div class="dashboard-metric">
                            {{ (revenueEnCours)|number_format(0, ',', ' ') }} MAD
                        </div>
                        <div class="text-muted mb-2">Demandes en cours - 90 derniers jours</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="dashboard-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="dashboard-title mb-0">Demandes par mois</div>
                            <select id="monthSelector" class="form-select form-select-sm" style="width: auto;">
                                {% for month in availableMonths %}
                                    <option value="{{ month.value }}" {% if month.value == selectedMonth %}selected{% endif %}>
                                        {{ month.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <canvas id="orderTimeChart" height="120" 
                            data-en-attente="{{ demandesStats.en_attente }}"
                            data-en-cours="{{ demandesStats.en_cours }}"
                            data-acceptee="{{ demandesStats.acceptee }}"
                            data-refusee="{{ demandesStats.refusee }}"></canvas>
                        <div class="text-center mt-2">
                            <span class="badge" style="background-color: #fd7e14;">En attente ({{ demandesStats.en_attente }})</span>
                            <span class="badge" style="background-color: #007bff;">En cours ({{ demandesStats.en_cours }})</span>
                            <span class="badge" style="background-color: #28a745;">Acceptée ({{ demandesStats.acceptee }})</span>
                            <span class="badge" style="background-color: #dc3545;">Refusée ({{ demandesStats.refusee }})</span>
                        </div>
                    </div>
                </div>
            </div>
            
            {# Ligne 2: Évolution des demandes #}
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="dashboard-card">
                        <div class="dashboard-title">Évolution des demandes</div>
                        <div class="text-muted mb-3" style="font-size: 0.875rem;">90 derniers jours</div>
                        <canvas id="evolutionChart" height="80"
                            data-evolution='{{ evolutionData|json_encode|raw }}'></canvas>
                    </div>
                </div>
            </div>
            
            {# Ligne 3: Top Villes + Demandes par catégorie #}
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="dashboard-card">
                        <div class="dashboard-title">Top 10 Villes</div>
                        <div class="text-muted mb-3" style="font-size: 0.875rem;">90 derniers jours</div>
                        <canvas id="topVillesChart" height="200"
                            data-villes='{{ topVilles|json_encode|raw }}'></canvas>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="dashboard-card">
                        <div class="dashboard-title">Demandes par catégorie</div>
                        <div class="text-muted mb-3" style="font-size: 0.875rem;">90 derniers jours</div>
                        <div style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead style="position: sticky; top: 0; background: white; z-index: 1;">
                                    <tr>
                                        <th>Catégorie</th>
                                        <th class="text-end">Demandes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for stat in categoriesStats %}
                                    <tr>
                                        <td>{{ stat.categorie }}</td>
                                        <td class="text-end">
                                            <span class="badge bg-primary">{{ stat.total }}</span>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="2" class="text-center text-muted">Aucune demande trouvée</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        {% elseif is_agent %}
            {# Vue statique pour les agents (données fixes inspirées du mock mobile) #}
            <style>
                .agent-shell { max-width: 860px; margin: 0 auto; display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
                .agent-donut { width: 260px; height: 260px; margin: 0 auto 20px; border-radius: 50%; background: conic-gradient(#fd7e14 0 25%, #007bff 25% 35%, #28a745 35% 80%, #dc3545 80% 100%); position: relative; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
                .agent-donut::before { content: ''; position: absolute; inset: 22%; background: #fff; border-radius: 50%; }
                .agent-legend .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 8px; }
                .agent-card { box-shadow: 0 10px 30px rgba(0,0,0,0.06); border: 1px solid #eef1f6; }
                .agent-mini { 
                    border: 1px solid #eef1f6; 
                    border-radius: 12px; 
                    padding: 16px; 
                    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
                    box-shadow: 0 6px 18px rgba(0,0,0,0.05); 
                    transition: all 0.3s ease;
                    position: relative;
                }
                .agent-mini:hover { 
                    box-shadow: 0 8px 24px rgba(0,0,0,0.1); 
                    transform: translateY(-2px);
                }
                .agent-mini-header { 
                    display: flex; 
                    align-items: center; 
                    gap: 10px; 
                    margin-bottom: 12px;
                }
                .agent-mini-icon {
                    width: 40px;
                    height: 40px;
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    border-radius: 10px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-size: 20px;
                    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
                }
                .agent-mini-month {
                    font-weight: 700;
                    font-size: 1.1rem;
                    color: #2c3e50;
                }
                .agent-status-badge {
                    margin-left: auto;
                    padding: 4px 8px;
                    border-radius: 20px;
                    font-size: 0.75rem;
                    font-weight: 600;
                    border: 1px solid transparent;
                }
                .agent-status-badge.paid {
                    background: #eaf7ea;
                    color: #28a745;
                    border-color: #cbe7cb;
                }
                .agent-status-badge.pending {
                    background: #fff5e6;
                    color: #fd7e14;
                    border-color: #ffe0b3;
                }
                .agent-mini-value {
                    font-size: 1.5rem;
                    font-weight: 700;
                    color: #2c3e50;
                    margin-bottom: 6px;
                }
                .agent-mini-trend {
                    font-size: 0.9rem;
                    font-weight: 600;
                    margin-left: 8px;
                }
                .agent-mini-stats {
                    display: flex;
                    flex-direction: column;
                    gap: 8px;
                    margin-top: 12px;
                    padding-top: 12px;
                    border-top: 1px solid #e9ecef;
                }
                .agent-mini-stat {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-size: 0.9rem;
                }
                .agent-mini-stat .dot {
                    width: 8px;
                    height: 8px;
                    border-radius: 50%;
                }
                .agent-mini-stat .dot.success { background: #28a745; }
                .agent-mini-stat .dot.danger { background: #dc3545; }
                .agent-mini-footer {
                    margin-top: 12px;
                    text-align: right;
                }
                .agent-mini-link {
                    display: inline-flex;
                    align-items: center;
                    gap: 4px;
                    font-size: 0.85rem;
                    color: #667eea;
                    text-decoration: none;
                    font-weight: 600;
                    transition: all 0.2s ease;
                }
                .agent-mini-link:hover {
                    color: #764ba2;
                    gap: 6px;
                }
                .agent-mini-link svg {
                    width: 14px;
                    height: 14px;
                    transition: transform 0.2s ease;
                }
                .agent-mini-link:hover svg {
                    transform: translateX(2px);
                }
                .agent-slider { display: flex; align-items: center; justify-content: center; gap: 12px; }
                .agent-slides-wrapper { overflow: hidden; width: 100%; }
                .agent-slides { display: flex; transition: transform 0.3s ease; gap: 12px; }
                .agent-slide { min-width: calc(50% - 6px); }
                .agent-nav-btn { border: 1px solid #dee2e6; background: #fff; width: 36px; height: 36px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 6px 18px rgba(0,0,0,0.05); cursor: pointer; transition: all 0.2s ease; }
                .agent-nav-btn:hover:not(:disabled) { background: #667eea; color: white; border-color: #667eea; }
                .agent-nav-btn:disabled { opacity: 0.5; cursor: not-allowed; }
            </style>
                {# agentMonths désormais alimenté depuis le contrôleur #}
            <div class="agent-shell">
                <div class="dashboard-card text-center agent-card" style="grid-column: span 2;">
                    <div class="dashboard-title mb-1">{{ currentMonthName }}</div>
                    <div class="text-muted mb-3" style="font-size: 0.9rem;">{{ totalPatientsCurrentMonth }} patients inscrits</div>
                    {% set total = demandesStats.en_attente + demandesStats.en_cours + demandesStats.acceptee + demandesStats.refusee %}
                    {% set attentePct = total > 0 ? (demandesStats.en_attente / total * 100) : 0 %}
                    {% set coursPct = total > 0 ? (demandesStats.en_cours / total * 100) : 0 %}
                    {% set accepteePct = total > 0 ? (demandesStats.acceptee / total * 100) : 0 %}
                    {% set refuseePct = total > 0 ? (demandesStats.refusee / total * 100) : 0 %}
                    {% set cumulAttente = attentePct %}
                    {% set cumulCours = cumulAttente + coursPct %}
                    {% set cumulAcceptee = cumulCours + accepteePct %}
                    <div class="agent-donut" style="background: conic-gradient(#fd7e14 0 {{ cumulAttente }}%, #007bff {{ cumulAttente }}% {{ cumulCours }}%, #28a745 {{ cumulCours }}% {{ cumulAcceptee }}%, #dc3545 {{ cumulAcceptee }}% 100%);"></div>
                    <div class="row agent-legend text-center g-3 px-5" style="max-width: 480px; margin: 0 auto;">
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="dot" style="background:#fd7e14"></span>
                            <div class="small text-muted">En attente</div>
                            <div class="fw-bold">{{ demandesStats.en_attente }}</div>
                        </div>
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="dot" style="background:#007bff"></span>
                            <div class="small text-muted">En cours</div>
                            <div class="fw-bold">{{ demandesStats.en_cours }}</div>
                        </div>
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="dot" style="background:#28a745"></span>
                            <div class="small text-muted">Acceptée</div>
                            <div class="fw-bold">{{ demandesStats.acceptee }}</div>
                        </div>
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="dot" style="background:#dc3545"></span>
                            <div class="small text-muted">Refusée</div>
                            <div class="fw-bold">{{ demandesStats.refusee }}</div>
                        </div>
                    </div>
                </div>
                <div class="agent-slider" style="grid-column: span 2;">
                    <button class="agent-nav-btn" id="agentPrev" aria-label="Précédent">‹</button>
                    <div class="agent-slides-wrapper" id="agentWrapper">
                        <div class="agent-slides" id="agentSlides">
                            {% for item in agentMonths %}
                                <div class="agent-slide">
                                    <div class="agent-mini h-100">
                                        <div class="agent-mini-header">
                                            <div class="agent-mini-icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width: 20px; height: 20px;">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                                </svg>
                                            </div>
                                            <div class="agent-mini-month">{{ item.label }}</div>
                                            <div class="agent-status-badge {{ item.status == 'Payer' ? 'paid' : 'pending' }}">{{ item.status }}</div>
                                        </div>
                                        <div class="agent-mini-value">
                                            {{ item.value }}
                                            <span class="agent-mini-trend {{ item.trendClass }}">{{ item.trend }}</span>
                                        </div>
                                        <div class="agent-mini-stats">
                                            <div class="agent-mini-stat">
                                                <span class="dot success"></span>
                                                <span style="color: #6c757d;">Accepté :</span>
                                                <span style="font-weight: 600; color: #28a745;">{{ item.accepted }}</span>
                                            </div>
                                            <div class="agent-mini-stat">
                                                <span class="dot danger"></span>
                                                <span style="color: #6c757d;">Non accepté :</span>
                                                <span style="font-weight: 600; color: #dc3545;">{{ item.rejected }}</span>
                                            </div>
                                        </div>
                                        <div class="agent-mini-footer">
                                            <a href="#" class="agent-mini-link"
                                               data-month="{{ item.label }}"
                                               data-amount="{{ item.value }}"
                                               data-trend="{{ item.trend }}"
                                               data-trend-class="{{ item.trendClass }}"
                                               data-status="{{ item.status }}"
                                               data-prev-en-cours="{{ item.prev_en_cours }}"
                                               data-prev-accepted="{{ item.prev_accepted }}"
                                               data-prev-rejected="{{ item.prev_rejected }}"
                                               data-curr-accepted="{{ item.curr_accepted }}"
                                               data-curr-rejected="{{ item.curr_rejected }}"
                                            >
                                                Voir plus
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    <button class="agent-nav-btn" id="agentNext" aria-label="Suivant">›</button>
                </div>
            </div>
            {# Modal Voir plus #}
            <div id="agentModal" class="agent-modal" style="display:none; position:fixed; inset:0; z-index:1050;">
                <div class="agent-modal-backdrop" style="position:absolute; inset:0; background:rgba(0,0,0,0.35);"></div>
                <div class="agent-modal-card" style="position:relative; max-width:520px; margin: 80px auto; background:#fff; border-radius:12px; box-shadow:0 12px 30px rgba(0,0,0,0.15); padding:16px 20px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="agent-mini-header">
                            <div class="agent-mini-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width: 20px; height: 20px;">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div class="agent-mini-month" id="agentModalMonth">Mois</div>
                        </div>
                        <div class="text-end">
                            <div class="agent-mini-value" id="agentModalAmount">0,00 DH</div>
                            <div id="agentModalTrend" class="agent-mini-trend">▲ 0%</div>
                        </div>
                    </div>
                    <div class="mb-2"><strong>Status :</strong> <span id="agentModalStatus">-</span></div>
                    <hr>
                    <div class="mb-2 fw-bold">Demande depuis le mois Précédien</div>
                    <ul class="list-unstyled mb-3" style="line-height:1.8;">
                        <li><span class="dot success" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#007bff;margin-right:8px;"></span> Demande En cours : <span id="agentModalPrevEnCours">0</span></li>
                        <li><span class="dot success" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#28a745;margin-right:8px;"></span> Demande Acceptée : <span id="agentModalPrevAccepted">0</span></li>
                        <li><span class="dot danger" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#dc3545;margin-right:8px;"></span> Demande Non Acceptée : <span id="agentModalPrevRejected">0</span></li>
                    </ul>
                    <div class="mb-2 fw-bold">Demande pour le mois en cours</div>
                    <ul class="list-unstyled mb-3" style="line-height:1.8;">
                        <li><span class="dot success" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#28a745;margin-right:8px;"></span> Demande Acceptée : <span id="agentModalCurrAccepted">0</span></li>
                        <li><span class="dot danger" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#dc3545;margin-right:8px;"></span> Demande Non Acceptée : <span id="agentModalCurrRejected">0</span></li>
                    </ul>
                    <div class="text-center">
                        <button id="agentModalClose" class="btn btn-secondary">Fermer</button>
                    </div>
                </div>
            </div>
            <script>
                (function(){
                    const wrapper = document.getElementById('agentWrapper');
                    const slides = document.getElementById('agentSlides');
                    const prev = document.getElementById('agentPrev');
                    const next = document.getElementById('agentNext');
                    if (!wrapper || !slides || !prev || !next) return;
                    const total = slides.children.length;
                    let index = 0; // index du premier élément visible

                    const compute = () => {
                        const first = slides.children[0];
                        if (!first) return { step: 0, maxIndex: 0, visible: 1 };
                        const rect = first.getBoundingClientRect();
                        const gapPx = parseFloat(getComputedStyle(slides).gap || '12');
                        const step = rect.width + gapPx;
                        const visible = Math.max(1, Math.round(wrapper.clientWidth / step));
                        const maxIndex = Math.max(0, total - visible);
                        return { step, maxIndex, visible };
                    };

                    let metrics = compute();

                    const clampIndex = () => {
                        if (index < 0) index = 0;
                        if (index > metrics.maxIndex) index = metrics.maxIndex;
                    };

                    const update = () => {
                        clampIndex();
                        slides.style.transform = `translateX(-${index * metrics.step}px)`;
                        prev.disabled = index === 0;
                        next.disabled = index >= metrics.maxIndex;
                    };

                    prev.addEventListener('click', () => {
                        index -= 1;
                        update();
                    });

                    next.addEventListener('click', () => {
                        index += 1;
                        update();
                    });

                    window.addEventListener('resize', () => {
                        metrics = compute();
                        update();
                    });

                    update();
                })();
            </script>
        {% elseif is_user %}
            <div class="dashboard-card text-center">
                <div class="dashboard-title mb-2">Aucune statistique disponible</div>
                <div class="text-muted">Connectez-vous avec un compte admin pour voir les graphiques.</div>
            </div>
        {% endif %}
    </div>
</div>
