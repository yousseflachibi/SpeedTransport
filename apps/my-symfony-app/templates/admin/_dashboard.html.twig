{# Partial: admin dashboard content #}
<div id="dashboard-root">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="dashboard-card">
                    <div class="dashboard-title">Revenue</div>
                    <div class="dashboard-metric">IDR 7.852.000 <span class="dashboard-badge bg-success">+2.1% vs last week</span></div>
                    <div class="text-muted mb-2">Sales from 1-12 Dec, 2020</div>
                    <canvas id="revenueChart" height="80"></canvas>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="dashboard-title">Order Time</div>
                    <canvas id="orderTimeChart" height="120"></canvas>
                    <div class="text-center mt-2">
                        <span class="badge bg-primary">Afternoon</span>
                        <span class="badge bg-secondary">Evening</span>
                        <span class="badge bg-info">Morning</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="dashboard-card text-center">
                    <div class="dashboard-title">Your Rating</div>
                    <div class="row">
                        <div class="col-4">
                            <div class="dashboard-circle hygiene">85%<br><small>Hygiene</small></div>
                        </div>
                        <div class="col-4">
                            <div class="dashboard-circle taste">85%<br><small>Food Taste</small></div>
                        </div>
                        <div class="col-4">
                            <div class="dashboard-circle packaging">92%<br><small>Packaging</small></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="dashboard-title">Most Ordered Food</div>
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between align-items-center">Fresh Salad Bowl <span>IDR 45.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Chicken Noodles <span>IDR 75.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Smoothie Fruits <span>IDR 65.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Hot Chicken Wings <span>IDR 55.000</span></li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="dashboard-title">Order</div>
                    <div class="dashboard-metric">2.568 <span class="dashboard-badge bg-danger">-2.1% vs last week</span></div>
                    <div class="text-muted mb-2">Sales from 1-6 Dec, 2020</div>
                    <canvas id="orderChart" height="60"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
