{# Partial: admin dashboard content #}
<div id="dashboard-root">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="dashboard-card">
                    <div class="dashboard-title">Revenue</div>
                    <div class="dashboard-metric">IDR 7.852.000 <span class="dashboard-badge bg-success">+2.1% vs last week</span></div>
                    <div class="text-muted mb-2">Sales from 1-12 Dec, 2020</div>
                    <canvas id="revenueChart" height="80"></canvas>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="dashboard-title mb-0">Demandes par mois</div>
                        <select id="monthSelector" class="form-select form-select-sm" style="width: auto;">
                            {% for month in availableMonths %}
                                <option value="{{ month.value }}" {% if month.value == selectedMonth %}selected{% endif %}>
                                    {{ month.label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <canvas id="orderTimeChart" height="120" 
                        data-en-attente="{{ demandesStats.en_attente }}"
                        data-en-cours="{{ demandesStats.en_cours }}"
                        data-acceptee="{{ demandesStats.acceptee }}"
                        data-refusee="{{ demandesStats.refusee }}"></canvas>
                    <div class="text-center mt-2">
                        <span class="badge" style="background-color: #fd7e14;">En attente ({{ demandesStats.en_attente }})</span>
                        <span class="badge" style="background-color: #007bff;">En cours ({{ demandesStats.en_cours }})</span>
                        <span class="badge" style="background-color: #28a745;">Acceptée ({{ demandesStats.acceptee }})</span>
                        <span class="badge" style="background-color: #dc3545;">Refusée ({{ demandesStats.refusee }})</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="dashboard-card text-center">
                    <div class="dashboard-title">Your Rating</div>
                    <div class="row">
                        <div class="col-4">
                            <div class="dashboard-circle hygiene">85%<br><small>Hygiene</small></div>
                        </div>
                        <div class="col-4">
                            <div class="dashboard-circle taste">85%<br><small>Food Taste</small></div>
                        </div>
                        <div class="col-4">
                            <div class="dashboard-circle packaging">92%<br><small>Packaging</small></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="dashboard-title">Most Ordered Food</div>
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between align-items-center">Fresh Salad Bowl <span>IDR 45.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Chicken Noodles <span>IDR 75.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Smoothie Fruits <span>IDR 65.000</span></li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">Hot Chicken Wings <span>IDR 55.000</span></li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dashboard-card">
                    <div class="dashboard-title">Demandes par catégorie</div>
                    <div class="text-muted mb-3" style="font-size: 0.875rem;">Derniers 90 jours</div>
                    <div style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead style="position: sticky; top: 0; background: white; z-index: 1;">
                                <tr>
                                    <th>Catégorie</th>
                                    <th class="text-end">Demandes</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for stat in categoriesStats %}
                                <tr>
                                    <td>{{ stat.categorie }}</td>
                                    <td class="text-end">
                                        <span class="badge bg-primary">{{ stat.total }}</span>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="2" class="text-center text-muted">Aucune demande trouvée</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
