{# Partial: services kine list #}
<div id="services-kine-root">
    <div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
        <div class="dashboard-title mb-0">Services Kiné</div>
        <button class="btn btn-primary" id="addServiceBtn">Ajouter</button>
    </div>
    
    <div class="dashboard-card mb-3">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label for="serviceCategorieFilter" class="form-label">Filtrer par catégorie</label>
                <select class="form-select" id="serviceCategorieFilter">
                    <option value="">Toutes les catégories</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {% if cat.id ~ '' == categorieFilter %}selected{% endif %}>{{ cat.nom }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-8 text-end">
                <span class="text-muted">{{ total }} service(s) trouvé(s)</span>
            </div>
        </div>
    </div>
    
    <div class="dashboard-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom du service</th>
                    <th>Catégorie</th>
                    <th>Prix</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for service in services %}
                <tr data-id="{{ service.id }}">
                    <td class="service-idx">{{ loop.index }}</td>
                    <td class="service-name">{{ service.name }}</td>
                    <td class="service-category">{{ service.categorie.nom }}</td>
                    <td class="service-price">{{ service.price }}</td>
                    <td>
                        <button class="btn btn-sm btn-warning service-kine-edit-btn" data-id="{{ service.id }}" onclick="editServiceKine(this)">Modifier</button>
                        <button class="btn btn-sm btn-danger service-kine-delete-btn" data-id="{{ service.id }}" onclick="deleteServiceKine(this)">Supprimer</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center">Aucun service</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        {% if totalPages > 1 %}
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
                Page {{ currentPage }} sur {{ totalPages }} ({{ total }} service(s) au total)
            </div>
            <nav aria-label="Pagination des services">
                <ul class="pagination mb-0">
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link service-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a>
                        </li>
                    {% else %}
                        <li class="page-item disabled">
                            <span class="page-link">Précédent</span>
                        </li>
                    {% endif %}
                    
                    {% for p in 1..totalPages %}
                        {% if p == currentPage %}
                            <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                        {% elseif p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                            <li class="page-item">
                                <a class="page-link service-page-link" href="#" data-page="{{ p }}">{{ p }}</a>
                            </li>
                        {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                    {% endfor %}
                    
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link service-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a>
                        </li>
                    {% else %}
                        <li class="page-item disabled">
                            <span class="page-link">Suivant</span>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        </div>
        {% endif %}
    </div>
    </div>
    {# Inclusion du tableau catégories juste après le tableau services kiné #}
    {% include 'admin/_categories_kine.html.twig' with { categories: categories } %}

    <!-- Modal Services Kiné (client-side only) -->
</div>

<!-- Modal Services Kiné (client-side only) -->
<div class="modal fade" id="serviceModal" tabindex="-1" aria-labelledby="serviceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="serviceModalLabel">Ajouter un service</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="serviceForm">
                    <input type="hidden" id="serviceId" value="">
                    <div id="serviceFormError" style="display:none;" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label for="serviceName" class="form-label">Nom du service</label>
                        <input type="text" class="form-control" id="serviceName" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="serviceCategory" class="form-label">Catégorie</label>
                        <select class="form-control" id="serviceCategory" name="category" required>
                            {% for cat in categories %}
                                <option value="{{ cat.id }}">{{ cat.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="servicePrice" class="form-label">Prix</label>
                        <input type="text" class="form-control" id="servicePrice" name="price" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="submit" form="serviceForm" class="btn btn-primary">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Notification placeholder for services -->
<div id="service-notif" style="position:fixed;top:80px;right:20px;z-index:2000"></div>


