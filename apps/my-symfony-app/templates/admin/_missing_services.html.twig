{# Partial: services demandés mais non couverts par un centre #}
<div class="dashboard-card mb-4 d-flex justify-content-between align-items-center">
    <div>
        <div class="dashboard-title mb-0">Services demandés non couverts</div>
        <p class="text-muted mb-0 small">Services demandés par les patients sans centre enregistré dans la ville/zone.</p>
    </div>
    <span class="badge bg-primary">{{ totalCount }} élément(s)</span>
</div>

<div class="dashboard-card mb-3">
    <div class="row g-3 align-items-end" id="missing-services-filter">
        <div class="col-md-6">
            <label for="missing-ville-filter" class="form-label">Filtrer par ville</label>
            <select class="form-select" id="missing-ville-filter" name="ville">
                <option value="">Toutes les villes</option>
                {% for id, name in villesMap %}
                    <option value="{{ id }}" {% if villeFilter and villeFilter == id %}selected{% endif %}>{{ name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-6 text-md-end text-muted">
            {{ totalCount }} résultat(s)
        </div>
    </div>
</div>

<div class="dashboard-card">
    {% if missingServices is not empty %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Service</th>
                        <th>Ville</th>
                        <th>Zone</th>
                        <th class="text-center">Demandes</th>
                        <th>Date de demande</th>
                        <th>Couverture</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in missingServices %}
                        {% set zoneInfo = zonesMap[entry.zoneId] ?? null %}
                        {% set villeLabel = zoneInfo ? zoneInfo.ville : (villesMap[entry.villeId] ?? '—') %}
                        {% set zoneLabel = zoneInfo ? zoneInfo.nom : '—' %}
                        <tr>
                            <td>{{ entry.serviceName }}</td>
                            <td>{{ villeLabel }}</td>
                            <td>{{ zoneLabel }}</td>
                            <td class="text-center"><span class="badge bg-dark">{{ entry.demandeCount }}</span></td>
                            <td>{% if entry.lastDemandeAt %}{{ entry.lastDemandeAt|date('d/m/Y') }}{% else %}—{% endif %}</td>
                            <td><span class="badge bg-danger">Aucun centre</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if totalPages > 1 %}
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted">Page {{ currentPage }} sur {{ totalPages }} ({{ totalCount }} au total)</div>
                <nav aria-label="Pagination services manquants">
                    <ul class="pagination mb-0">
                        {% if currentPage > 1 %}
                            <li class="page-item"><a class="page-link missing-services-page-link" href="#" data-page="{{ currentPage - 1 }}">Précédent</a></li>
                        {% else %}
                            <li class="page-item disabled"><span class="page-link">Précédent</span></li>
                        {% endif %}

                        {% for p in 1..totalPages %}
                            {% if p == currentPage %}
                                <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                            {% elseif p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                                <li class="page-item"><a class="page-link missing-services-page-link" href="#" data-page="{{ p }}">{{ p }}</a></li>
                            {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                            <li class="page-item"><a class="page-link missing-services-page-link" href="#" data-page="{{ currentPage + 1 }}">Suivant</a></li>
                        {% else %}
                            <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
        {% endif %}
    {% else %}
        <div class="text-center text-muted py-4">Tous les services demandés sont déjà couverts par les centres enregistrés.</div>
    {% endif %}
</div>

<script>
// Sécurise le rebinding même si un reload partiel a raté le hook global
if (window.attachMissingServicesHandlers) {
    window.attachMissingServicesHandlers();
}
</script>

