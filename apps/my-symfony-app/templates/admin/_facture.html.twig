<div class="admin-facture">
    <h2>Factures</h2>

    <div class="mb-3">
        <label for="agentSelect" class="form-label">Sélectionnez un agent</label>
        <select id="agentSelect" class="form-select">
            <option value="">-- Choisir un agent --</option>
            {% for agent in agents %}
                <option value="{{ agent.id }}">{{ agent.email }} ({{ agent.fullName ? agent.fullName : agent.email }})</option>
            {% endfor %}
        </select>
    </div>

    <!-- Section des mois de travaux -->
    <div id="workMonthsSection" style="display:none" class="mb-5">
        <h5 class="mb-3">Mois de travaux</h5>
        <div id="workMonthsContainer" class="row" style="gap: 1rem;"></div>
    </div>

    <!-- Modal detail -->
    <div class="modal fade" id="invoiceDetailModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Détail de la facture</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id="invoiceDetailBody">Chargement...</div>
        </div>
      </div>
    </div>

    <style>
        .work-month-card {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 1.5rem;
            min-width: 280px;
            flex: 0 1 calc(50% - 0.5rem);
            display: flex;
            flex-direction: column;
        }
        .work-month-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }
        .work-month-card-title {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .work-month-card-title svg {
            width: 24px;
            height: 24px;
            color: #6366f1;
        }
        .work-month-card-status {
            background: #d4edda;
            color: #155724;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
        }
        .work-month-card-status.pending {
            background: #fff3cd;
            color: #856404;
        }
        .work-month-card-amount {
            font-size: 1.75rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 0.5rem;
        }
        .work-month-card-trend {
            font-size: 0.9rem;
            color: #28a745;
            margin-bottom: 1rem;
        }
        .work-month-card-trend.down {
            color: #dc3545;
        }
        .work-month-card-stats {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: #666;
        }
        .work-month-stat {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .work-month-stat-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .stat-accepted { background-color: #28a745; }
        .stat-rejected { background-color: #dc3545; }
        .stat-en-cours { background-color: #007bff; }
        .stat-en-attente { background-color: #ffc107; }
    </style>

    <!-- Scripts sont gérés dans index.html.twig via attachFactureHandlers() -->
</div>
