{% extends 'base.html.twig' %}

{% block title %}Speed Transport — Transport Express & Logistique B2B · IDF & International{% endblock %}

{% block stylesheets %}
<style>
:root{--or:#f97316;--or2:#ea580c;--or3:#c2410c;--noir:#090909;--noir2:#111;--noir3:#1a1a1a;--noir4:#222;--gris:#888;--gris2:#555;--blanc:#f5f0eb;--b2:rgba(245,240,235,.65);--b3:rgba(245,240,235,.1);--r:8px}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
body{font-family:'Barlow',sans-serif;background:var(--noir);color:var(--blanc);overflow-x:hidden}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.28;mix-blend-mode:overlay;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E")}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;background:rgba(9,9,9,.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(249,115,22,.12);transition:transform .3s}
.nl{font-family:'Bebas Neue',sans-serif;font-size:1.65rem;letter-spacing:.06em;color:var(--blanc);display:flex;align-items:center;gap:8px}.nl span{color:var(--or)}
.nl sup{font-family:'Barlow',sans-serif;font-size:.52rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--or);border:1px solid rgba(249,115,22,.45);padding:1px 7px;border-radius:99px;margin-top:5px}
.nlinks{display:flex;gap:2rem;list-style:none}.nlinks a{font-size:.75rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--b2);text-decoration:none;transition:color .2s}.nlinks a:hover{color:var(--or)}
.nwa{display:flex;align-items:center;gap:8px;background:#25d366;color:#fff;font-size:.8rem;font-weight:700;padding:.5rem 1.2rem;border-radius:99px;text-decoration:none;transition:background .2s}.nwa:hover{background:#1ebe5d}
/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;padding:8rem 3rem 4rem;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-62deg,transparent,transparent 42px,rgba(249,115,22,.025) 42px,rgba(249,115,22,.025) 43px)}
.hero::after{content:'';position:absolute;top:-15%;right:-8%;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(249,115,22,.1) 0%,transparent 68%);pointer-events:none}
.hbg{position:absolute;right:-1rem;bottom:-4rem;font-family:'Bebas Neue',sans-serif;font-size:26vw;color:rgba(255,255,255,.018);line-height:1;pointer-events:none;letter-spacing:-.02em;z-index:0;user-select:none}
.hey{display:inline-flex;align-items:center;gap:8px;font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--or);border:1px solid rgba(249,115,22,.3);padding:5px 14px;border-radius:99px;margin-bottom:1.8rem;position:relative;z-index:1;animation:fu .6s ease both}
.hey::before{content:'●';font-size:7px}
h1.ht{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.8rem,8vw,7.5rem);line-height:.92;letter-spacing:.01em;position:relative;z-index:1;animation:fu .6s .1s ease both;max-width:980px}
.l1{display:block;color:var(--blanc)}.l2{display:block;color:var(--or)}.l3{display:block;-webkit-text-stroke:2px rgba(245,240,235,.35);color:transparent;font-size:clamp(2rem,5.5vw,5rem)}
.hsub{font-size:.97rem;font-weight:300;line-height:1.85;color:var(--b2);max-width:560px;margin:1.8rem 0 .8rem;position:relative;z-index:1;animation:fu .6s .2s ease both}
.hsub strong{color:var(--blanc);font-weight:600}
.hint{display:inline-flex;align-items:center;gap:8px;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.25);color:var(--or);font-size:.78rem;font-weight:600;padding:6px 14px;border-radius:99px;margin-bottom:2rem;position:relative;z-index:1;animation:fu .6s .25s ease both}
.hact{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;position:relative;z-index:1;animation:fu .6s .3s ease both}
.bwa{display:inline-flex;align-items:center;gap:10px;background:#25d366;color:#fff;font-size:.95rem;font-weight:700;padding:.95rem 2.2rem;border-radius:99px;text-decoration:none;transition:all .25s;box-shadow:0 0 28px rgba(37,211,102,.3)}
.bwa:hover{background:#1ebe5d;transform:translateY(-2px);box-shadow:0 0 42px rgba(37,211,102,.45)}
.bor{display:inline-flex;align-items:center;gap:8px;background:var(--or);color:#fff;font-size:.9rem;font-weight:700;padding:.9rem 1.8rem;border-radius:var(--r);text-decoration:none;transition:all .25s}
.bor:hover{background:var(--or2);transform:translateY(-2px)}
.hkpi{display:flex;gap:3rem;margin-top:3.5rem;padding-top:2rem;border-top:1px solid var(--b3);position:relative;z-index:1;animation:fu .6s .4s ease both;flex-wrap:wrap}
.kn{font-family:'Bebas Neue',sans-serif;font-size:2.6rem;color:var(--or);line-height:1;display:block}.kl{font-size:.65rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gris);margin-top:4px}
/* TICKER */
.ticker{background:var(--or);padding:.55rem 0;overflow:hidden}
.ttrack{display:flex;white-space:nowrap;animation:tick 32s linear infinite}
.ti{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:.08em;color:#fff;padding:0 2.5rem;flex-shrink:0;display:flex;align-items:center;gap:1rem}.ti::after{content:'◆';font-size:.45rem;opacity:.6}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
/* SECTION */
.sec{padding:6rem 3rem}.ctn{max-width:1200px;margin:0 auto}
.stag{display:inline-flex;align-items:center;gap:8px;font-size:.62rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--or);margin-bottom:1rem}.stag::before{content:'';width:18px;height:2px;background:var(--or);display:block}
.sti{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.2rem,4.5vw,3.6rem);line-height:1;letter-spacing:.02em;color:var(--blanc);margin-bottom:.8rem}
.ssub{font-size:.92rem;font-weight:300;color:var(--b2);line-height:1.85;max-width:580px}
/* ABOUT */
.ab-bg{background:var(--noir2);position:relative;overflow:hidden}
.ab-bg::before{content:'';position:absolute;left:-10%;top:-20%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(249,115,22,.05) 0%,transparent 65%);pointer-events:none}
.alay{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.aquote{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.7rem,3vw,2.6rem);line-height:1.12;letter-spacing:.02em;color:var(--blanc);margin:1.5rem 0 2rem;border-left:3px solid var(--or);padding-left:1.5rem}.aquote span{color:var(--or)}
.acards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:2rem}
.acard{background:var(--noir3);border:1px solid var(--b3);border-radius:var(--r);padding:1rem;text-align:center;transition:border-color .2s}.acard:hover{border-color:rgba(249,115,22,.4)}
.acn{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--or);display:block;line-height:1}.acl{font-size:.68rem;color:var(--gris);letter-spacing:.08em;text-transform:uppercase;margin-top:3px}
.aparas p{font-size:.9rem;font-weight:300;line-height:1.9;color:var(--b2);margin-bottom:1.2rem}.aparas p strong{color:var(--blanc);font-weight:600}.aparas p:last-child{margin-bottom:0}
/* SERVICES */
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--b3);margin-top:3.5rem;border:1px solid var(--b3)}
.sc{background:var(--noir);padding:2.5rem 2rem;position:relative;overflow:hidden;transition:background .2s}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--or);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.sc:hover{background:var(--noir3)}.sc:hover::before{transform:scaleX(1)}
.scn{position:absolute;top:.8rem;right:1.2rem;font-family:'Bebas Neue',sans-serif;font-size:4rem;color:rgba(249,115,22,.055);line-height:1;pointer-events:none}
.sci{font-size:1.8rem;display:block;margin-bottom:1.2rem}
.scname{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:.04em;color:var(--blanc);margin-bottom:.6rem}
.scdesc{font-size:.83rem;font-weight:300;line-height:1.8;color:var(--b2);margin-bottom:1rem}
.sczone{background:rgba(249,115,22,.07);border:1px solid rgba(249,115,22,.15);border-radius:5px;padding:.7rem .9rem;margin-bottom:1rem;font-size:.78rem;font-weight:300;color:rgba(245,240,235,.6);line-height:1.7}
.sczone strong{color:var(--or);font-weight:600;display:block;margin-bottom:3px;font-size:.7rem;letter-spacing:.08em;text-transform:uppercase}
.scb{list-style:none;display:flex;flex-direction:column;gap:5px}
.scb li{font-size:.78rem;color:var(--gris);display:flex;align-items:flex-start;gap:7px}.scb li::before{content:'→';color:var(--or);flex-shrink:0}
.intlbadge{display:block;background:linear-gradient(135deg,rgba(249,115,22,.15),rgba(194,65,12,.1));border:1px solid rgba(249,115,22,.35);border-radius:5px;padding:.45rem .85rem;font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--or);margin-bottom:1rem}
/* POUR QUI */
.pqbg{background:var(--noir2)}
.pqlay{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.pqlist{display:flex;flex-direction:column;gap:.8rem;margin-top:2rem}
.pqi{display:flex;align-items:center;gap:1rem;background:var(--noir3);border:1px solid var(--b3);border-radius:var(--r);padding:1rem 1.4rem;transition:border-color .2s}.pqi:hover{border-color:rgba(249,115,22,.4)}
.pqic{font-size:1.4rem;flex-shrink:0}.pqt{font-size:.9rem;font-weight:500;color:var(--blanc)}.pqd{font-size:.75rem;color:var(--gris);margin-top:2px}
.impbox{background:var(--or);border-radius:var(--r);padding:2.5rem;position:relative;overflow:hidden}
.impbox::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-55deg,transparent,transparent 20px,rgba(0,0,0,.05) 20px,rgba(0,0,0,.05) 21px)}
.impq{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,2.8vw,2.3rem);line-height:1.15;letter-spacing:.02em;color:#fff;position:relative;z-index:1}
.imps{font-size:.82rem;font-weight:300;color:rgba(255,255,255,.8);margin-top:1rem;line-height:1.7;position:relative;z-index:1}
.impwa{display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--or2);font-size:.85rem;font-weight:700;padding:.75rem 1.5rem;border-radius:99px;text-decoration:none;margin-top:1.5rem;transition:all .2s;position:relative;z-index:1}
.impwa:hover{background:rgba(255,255,255,.9);transform:translateY(-2px)}
/* POURQUOI */
.whybg{background:var(--noir);position:relative;overflow:hidden}
.whybg::after{content:'';position:absolute;right:-5%;top:-10%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(249,115,22,.07) 0%,transparent 65%);pointer-events:none}
.whygrid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--b3);margin-top:3.5rem}
.whi{background:var(--noir);padding:2rem 1.5rem;text-align:center;transition:background .2s}.whi:hover{background:var(--noir3)}
.whck{width:44px;height:44px;border-radius:50%;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.3);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:var(--or);font-size:1rem;font-weight:700}
.wht{font-size:.82rem;font-weight:500;color:var(--blanc);line-height:1.6;text-align:center}
/* ZONES */
.zbg{background:var(--noir2)}
.zlay{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:3rem}
.zhdr{font-size:.6rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--gris2);padding:.5rem 0;border-bottom:1px solid var(--b3);margin-bottom:.5rem;display:grid;grid-template-columns:2fr 1fr}
.dr{display:grid;grid-template-columns:2fr 1fr;align-items:center;padding:.5rem .8rem;border-radius:5px;cursor:pointer;transition:background .2s,border-color .2s,transform .22s;border:1px solid transparent}.dr:hover,.dr.zhover{background:var(--noir3);border-color:rgba(249,115,22,.38)!important;transform:translateX(5px)}.dr:hover .dnum,.dr.zhover .dnum{color:var(--or);transition:color .2s}
#zones svg polygon{transition:filter .28s ease,opacity .28s ease;cursor:pointer}#zones svg polygon.zhover{filter:drop-shadow(0 0 9px rgba(249,115,22,.85)) brightness(1.45)}#zones svg polygon.zdim{opacity:.28}
.dr.idf{border-left:2px solid var(--or)}
.dn{font-size:.82rem;font-weight:500;color:var(--blanc);display:flex;align-items:center;gap:7px}
.db{font-size:.58rem;font-weight:700;padding:2px 7px;border-radius:99px;letter-spacing:.05em;text-transform:uppercase}
.bidf{background:rgba(249,115,22,.18);color:var(--or)}.bzone{background:rgba(255,255,255,.06);color:var(--gris)}.bbase{background:rgba(249,115,22,.3);color:#fff}
.dnum{font-size:.75rem;color:var(--gris);font-weight:500}
.mapbox{background:var(--noir2);border:1px solid rgba(249,115,22,.3);border-radius:var(--r);padding:1.5rem;box-shadow:0 0 32px rgba(249,115,22,.06)}
.maplbl{font-size:.6rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gris);margin-bottom:1rem;display:flex;align-items:center;gap:8px}.maplbl::before{content:'';width:14px;height:2px;background:var(--or);display:block}
.mapleg{display:flex;gap:1rem;margin-top:1rem;flex-wrap:wrap}.mli{display:flex;align-items:center;gap:6px;font-size:.68rem;color:var(--gris)}.mld{width:10px;height:10px;border-radius:2px;flex-shrink:0}
/* TEMOIGNAGES */
.tbg{background:var(--noir)}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
.tc{background:var(--noir2);border:1px solid var(--b3);border-radius:var(--r);overflow:hidden;transition:border-color .2s}.tc:hover{border-color:rgba(249,115,22,.35)}
.vt{position:relative;aspect-ratio:16/9;background:var(--noir4);display:flex;align-items:center;justify-content:center;overflow:hidden;cursor:pointer}
.vtbg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:4rem;opacity:.12}
.play{width:56px;height:56px;background:var(--or);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;z-index:1;transition:transform .2s,box-shadow .2s}
.vt:hover .play{transform:scale(1.12);box-shadow:0 0 0 14px rgba(249,115,22,.15)}
.ptri{width:0;height:0;border-top:10px solid transparent;border-bottom:10px solid transparent;border-left:18px solid #fff;margin-left:4px}
.vdur{position:absolute;bottom:.6rem;right:.6rem;background:rgba(0,0,0,.8);color:#fff;font-size:.62rem;font-weight:600;padding:2px 7px;border-radius:3px;letter-spacing:.05em}
.tbody{padding:1.3rem}.tst{color:var(--or);font-size:.85rem;margin-bottom:.6rem}
.ttxt{font-size:.83rem;font-weight:300;color:var(--b2);line-height:1.7;margin-bottom:1rem}
.tauth{display:flex;align-items:center;gap:10px}.tav{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:#fff;flex-shrink:0}
.tname{font-size:.85rem;font-weight:600;color:var(--blanc)}.trole{font-size:.7rem;color:var(--gris)}
/* MODAL */
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:1000;align-items:center;justify-content:center}.modal.open{display:flex}
.mbox{background:var(--noir2);border-radius:var(--r);padding:1.5rem;width:90%;max-width:680px;border:1px solid var(--b3)}
.mtop{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
.mttl{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.05em;color:var(--blanc)}
.mcls{background:none;border:1px solid var(--b3);color:var(--b2);width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all .2s}.mcls:hover{border-color:var(--or);color:var(--or)}
.mvid{aspect-ratio:16/9;background:var(--noir);border-radius:5px;display:flex;align-items:center;justify-content:center}
.mph{text-align:center;color:var(--b2);font-size:.85rem}.mph div{font-size:2.5rem;margin-bottom:.5rem}
.mq{margin-top:1.2rem;padding:1rem;background:var(--noir3);border-radius:5px;border-left:3px solid var(--or);font-size:.88rem;font-style:italic;color:var(--b2);line-height:1.7}
/* DEVIS */
.dvbg{background:var(--noir2);position:relative;overflow:hidden}
.dvbg::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-62deg,transparent,transparent 42px,rgba(249,115,22,.018) 42px,rgba(249,115,22,.018) 43px)}
.dvlay{display:grid;grid-template-columns:1fr 1.5fr;gap:4rem;align-items:start;position:relative;z-index:1}
.perks{display:flex;flex-direction:column;gap:.9rem;margin-top:2rem}
.pk{display:flex;align-items:flex-start;gap:.9rem;background:var(--b3);border-radius:var(--r);border:1px solid rgba(249,115,22,.1);padding:1rem 1.2rem}
.pkic{font-size:1.2rem;flex-shrink:0;margin-top:1px}.pkttl{font-size:.85rem;font-weight:600;color:var(--blanc);margin-bottom:3px}.pkdsc{font-size:.76rem;color:var(--gris);line-height:1.6}
.fbox{background:var(--noir3);border:1px solid var(--b3);border-radius:var(--r);padding:2.5rem}
.fbox h3{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;letter-spacing:.04em;color:var(--blanc);margin-bottom:.3rem}
.fsub{font-size:.75rem;color:var(--gris);margin-bottom:2rem}
.fg{margin-bottom:.9rem}.fg label{font-size:.62rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--gris);display:block;margin-bottom:5px}
.fg input,.fg select,.fg textarea{width:100%;background:var(--noir);border:1px solid var(--b3);border-radius:5px;padding:.68rem .9rem;font-size:.88rem;font-family:'Barlow',sans-serif;color:var(--blanc);outline:none;transition:border .2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--or)}.fg select option{background:var(--noir)}.fg textarea{resize:vertical;min-height:85px}.fg input::placeholder,.fg textarea::placeholder{color:var(--gris2)}
.f2{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
.bsub{width:100%;background:var(--or);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.08em;padding:1rem;border:none;border-radius:var(--r);cursor:pointer;transition:all .2s;margin-top:.5rem;box-shadow:0 0 20px rgba(249,115,22,.2)}
.bsub:hover{background:var(--or2);box-shadow:0 0 32px rgba(249,115,22,.4);transform:translateY(-2px)}
.bwaf{width:100%;display:flex;align-items:center;justify-content:center;gap:9px;background:transparent;color:rgba(245,240,235,.5);font-size:.8rem;font-weight:600;border:1px solid var(--b3);padding:.7rem;border-radius:var(--r);cursor:pointer;text-decoration:none;transition:all .2s;margin-top:.6rem}.bwaf:hover{border-color:#25d366;color:#25d366}
.fok{display:none;text-align:center;padding:2.5rem 1rem}.fokic{font-size:3rem;display:block;margin-bottom:1rem}
.fok h3{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.04em;color:var(--blanc);margin-bottom:.5rem}
.fok p{font-size:.88rem;color:var(--b2);line-height:1.7}
/* FOOTER */
footer{background:var(--noir);border-top:1px solid var(--b3);padding:3.5rem 3rem}
.fin{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem}
.flog{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.06em;color:var(--blanc);margin-bottom:1rem}.flog span{color:var(--or)}
.fdsc{font-size:.8rem;font-weight:300;color:var(--gris);line-height:1.85;margin-bottom:1.5rem}.fleg{font-size:.68rem;color:var(--gris2);line-height:1.85}
.fcol h4{font-size:.6rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gris2);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid var(--b3)}
.fcol ul{list-style:none;display:flex;flex-direction:column;gap:.5rem}.fcol a{font-size:.8rem;color:var(--gris);text-decoration:none;transition:color .2s}.fcol a:hover{color:var(--or)}
.fbot{max-width:1200px;margin:2rem auto 0;padding-top:1.5rem;border-top:1px solid var(--b3);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;font-size:.7rem;color:var(--gris2)}
