{% block javascripts %}
{{ parent() }}
<script>
let ly=0;
window.addEventListener('scroll',()=>{const n=document.getElementById('nav'),y=window.scrollY;n.style.transform=(y>ly&&y>80)?'translateY(-100%)':'translateY(0)';n.style.transition='transform .3s';ly=y});
document.querySelectorAll('.rev').forEach(r=>new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')}),{threshold:.08}).observe(r));
function openM(t,q){document.getElementById('mt').textContent=t;document.getElementById('mq').textContent='« '+q+' »';document.getElementById('modal').classList.add('open');document.body.style.overflow='hidden'}
function closeM(){document.getElementById('modal').classList.remove('open');document.body.style.overflow=''}
function closeOut(e){if(e.target.id==='modal')closeM()}
function sendF(){document.getElementById('fc').style.display='none';document.getElementById('fok').style.display='block'}
// Zone hover sync liste <-> carte
(function(){
  const allPolys=document.querySelectorAll('#zones svg polygon');
  function activate(code){
    const poly=document.getElementById('dept-'+code);
    const row=document.querySelector('.dr[data-dept="'+code+'"]');
    allPolys.forEach(p=>{if(p.id!=='dept-'+code)p.classList.add('zdim');});
    if(poly){poly.classList.add('zhover');poly.classList.remove('zdim');}
    if(row)row.classList.add('zhover');
  }
  function deactivate(code){
    const poly=document.getElementById('dept-'+code);
    const row=document.querySelector('.dr[data-dept="'+code+'"]');
    allPolys.forEach(p=>{p.classList.remove('zdim','zhover');});
    if(row)row.classList.remove('zhover');
  }
  document.querySelectorAll('.dr[data-dept]').forEach(row=>{
    const code=row.dataset.dept;
    row.addEventListener('mouseenter',()=>activate(code));
    row.addEventListener('mouseleave',()=>deactivate(code));
  });
  allPolys.forEach(poly=>{
    const code=poly.id.replace('dept-','');
    poly.addEventListener('mouseenter',()=>activate(code));
    poly.addEventListener('mouseleave',()=>deactivate(code));
  });
})();
</script>
{% endblock %}
