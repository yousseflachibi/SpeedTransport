/* WA FLOAT */
.waf{position:fixed;bottom:2rem;right:2rem;z-index:800}
.wafb{display:flex;align-items:center;gap:10px;background:#25d366;color:#fff;font-size:.83rem;font-weight:700;padding:.85rem 1.5rem;border-radius:99px;text-decoration:none;box-shadow:0 6px 24px rgba(37,211,102,.35);transition:all .2s;animation:wap 2.5s infinite}
.wafb:hover{background:#1ebe5d;transform:translateY(-3px)}
@keyframes wap{0%,100%{box-shadow:0 6px 24px rgba(37,211,102,.35)}50%{box-shadow:0 6px 38px rgba(37,211,102,.55)}}
.wlbl{font-size:.78rem;font-weight:700}.wsub{font-size:.6rem;opacity:.85;display:block}
/* ANIM */
@keyframes fu{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
.rev{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}.rev.vis{opacity:1;transform:translateY(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}
/* RESPONSIVE */
@media(max-width:960px){nav{padding:0 1.5rem}.nlinks{display:none}.hero{padding:6.5rem 1.5rem 3rem}.sec{padding:4rem 1.5rem}.alay,.pqlay,.zlay,.dvlay{grid-template-columns:1fr}.sg{grid-template-columns:1fr}.whygrid{grid-template-columns:1fr 1fr}.tgrid{grid-template-columns:1fr}.f2{grid-template-columns:1fr}.fin{grid-template-columns:1fr 1fr}.hkpi{gap:1.5rem}}
